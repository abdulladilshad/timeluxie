<!DOCTYPE html>
<html lang="en">

<head>
  <title>The Journal | LUXE TIME</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
    rel="stylesheet">

  <style>
    :root {
      --ivory: #F5F1EB;
      --charcoal: #1A1A1A;
      --gold: #C5A66E;
      --warm-gray: #8C8C8C;
      --font-serif: 'Playfair Display', serif;
      --font-sans: 'Inter', sans-serif;
    }

    body {
      background-color: var(--ivory);
      color: var(--charcoal);
      font-family: var(--font-sans);
      margin: 0;
      padding: 0;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6,
    .serif {
      font-family: var(--font-serif);
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    /* 1. Top Bar & Navigation (Consistent with index.ejs) */
    .top-bar {
      background-color: var(--charcoal);
      color: var(--ivory);
      text-align: center;
      padding: 8px 0;
      font-size: 0.8rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      font-weight: 300;
    }

    .navbar-luxury {
      background-color: var(--ivory);
      padding: 20px 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(26, 26, 26, 0.1);
      position: sticky;
      top: 0;
      z-index: 1000;
      backdrop-filter: blur(10px);
      /* Add a slight "glasing" effect */
      background-color: rgba(245, 241, 235, 0.9);
    }

    .navbar-brand h1 {
      margin: 0;
      font-size: clamp(1.4rem, 2vw, 1.8rem);
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--charcoal);
    }

    .nav-links {
      display: flex;
      gap: 30px;
    }

    .nav-links a {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 500;
      position: relative;
      transition: color 0.3s;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      width: 0;
      height: 1px;
      bottom: -4px;
      left: 0;
      background-color: var(--gold);
      transition: width 0.3s;
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: var(--gold);
    }

    .nav-links a:hover::after,
    .nav-links a.active::after {
      width: 100%;
    }

    .nav-icons {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .nav-icons a {
      font-size: 1.1rem;
      transition: color 0.3s;
    }

    .nav-icons a:hover {
      color: var(--gold);
    }

    .profile-img-nav {
      width: 25px;
      height: 25px;
      border-radius: 50%;
      object-fit: cover;
    }

    .mobile-menu-btn {
      display: none;
      font-size: 1.5rem;
      cursor: pointer;
      background: none;
      border: none;
      color: var(--charcoal);
    }

    @media (max-width: 991px) {
      .nav-links {
        display: none;
      }

      .nav-icons {
        display: none;
      }

      .mobile-menu-btn {
        display: block;
      }
    }

    /* Mobile Offcanvas Overrides */
    .offcanvas {
      background-color: var(--charcoal);
      color: var(--ivory);
    }

    .offcanvas .btn-close {
      filter: invert(1) grayscale(100%) brightness(200%);
    }

    .offcanvas a {
      color: var(--ivory);
      font-family: var(--font-serif);
      font-size: 1.5rem;
      margin-bottom: 20px;
      display: block;
    }

    .offcanvas a:hover {
      color: var(--gold);
    }

    /* 2. Page Header */
    .journal-header {
      padding: 80px 5% 40px;
      text-align: center;
    }

    .journal-header h1 {
      font-size: clamp(3rem, 5vw, 4.5rem);
      margin-bottom: 15px;
      color: var(--charcoal);
      font-weight: 400;
    }

    .journal-header p {
      font-size: clamp(1rem, 1.5vw, 1.2rem);
      color: var(--warm-gray);
      font-weight: 300;
      letter-spacing: 0.5px;
    }

    /* 4. Category Filter */
    .category-filter {
      display: flex;
      justify-content: center;
      gap: 30px;
      padding: 0 5% 40px;
      border-bottom: 1px solid rgba(26, 26, 26, 0.1);
      margin-bottom: 60px;
    }

    .category-pill {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--warm-gray);
      padding-bottom: 5px;
      cursor: pointer;
      transition: color 0.3s;
      white-space: nowrap;
    }

    .category-pill:hover,
    .category-pill.active {
      color: var(--charcoal);
      border-bottom: 2px solid var(--gold);
    }

    @media (max-width: 768px) {
      .category-filter {
        justify-content: flex-start;
        overflow-x: auto;
        padding-bottom: 20px;
        scrollbar-width: none;
        /* Firefox */
      }

      .category-filter::-webkit-scrollbar {
        display: none;
        /* Chrome */
      }

      .category-pill {
        padding-bottom: 10px;
      }
    }

    /* 3. Featured Article */
    .featured-article {
      padding: 0 5% 80px;
      display: block;
    }

    .featured-card {
      position: relative;
      width: 100%;
      height: 600px;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
      text-decoration: none;
    }

    .featured-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }

    .featured-card:hover .featured-image {
      transform: scale(1.03);
    }

    .featured-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.2) 50%, rgba(0, 0, 0, 0) 100%);
    }

    .featured-content {
      position: relative;
      z-index: 2;
      padding: 60px;
      color: var(--ivory);
      max-width: 800px;
    }

    .category-tag {
      color: var(--gold);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 15px;
      display: block;
    }

    .featured-content h2 {
      font-size: clamp(2rem, 3.5vw, 3.5rem);
      margin-bottom: 20px;
      line-height: 1.2;
    }

    .article-meta {
      display: flex;
      gap: 15px;
      font-size: 0.85rem;
      color: #CCC;
      margin-bottom: 20px;
      font-weight: 300;
    }

    .article-meta span {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .read-more-link {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--ivory);
      border-bottom: 1px solid var(--gold);
      padding-bottom: 5px;
      transition: color 0.3s, border-color 0.3s;
      display: inline-block;
    }

    .featured-card:hover .read-more-link {
      color: var(--gold);
    }

    @media (max-width: 768px) {
      .featured-card {
        height: auto;
        flex-direction: column;
        align-items: stretch;
      }

      .featured-image {
        position: relative;
        height: 300px;
      }

      .featured-overlay {
        display: none;
      }

      .featured-content {
        padding: 30px 0 0 0;
        color: var(--charcoal);
      }

      .article-meta {
        color: var(--warm-gray);
      }

      .read-more-link {
        color: var(--charcoal);
      }
    }

    /* 5. Article Grid */
    .journal-grid {
      padding: 0 5% 80px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }

    .article-card {
      text-decoration: none;
      display: flex;
      flex-direction: column;
      group: hover;
    }

    .article-image-wrapper {
      width: 100%;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      margin-bottom: 25px;
    }

    .article-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .article-card:hover .article-image {
      transform: scale(1.05);
    }

    .article-card:hover {
      transform: translateY(-5px);
      transition: transform 0.3s ease;
    }

    .article-card .category-tag {
      margin-bottom: 10px;
    }

    .article-title {
      font-family: var(--font-serif);
      font-size: clamp(1.2rem, 1.5vw, 1.5rem);
      color: var(--charcoal);
      margin-bottom: 15px;
      line-height: 1.3;
    }

    .article-excerpt {
      color: var(--warm-gray);
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 15px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .article-date {
      font-size: 0.8rem;
      color: #AAA;
      font-weight: 300;
      margin-top: auto;
    }

    @media (max-width: 991px) {
      .journal-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .journal-grid {
        grid-template-columns: 1fr;
        gap: 50px;
      }

      .article-card:hover {
        transform: none;
      }
    }

    /* 6. Load More Button */
    .load-more-container {
      text-align: center;
      padding: 0 5% 100px;
    }

    .btn-outline-gold {
      background: transparent;
      color: var(--gold);
      border: 1px solid var(--gold);
      padding: 15px 40px;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .btn-outline-gold:hover {
      background: var(--gold);
      color: var(--ivory);
    }

    @media (max-width: 768px) {
      .btn-outline-gold {
        width: 100%;
      }
    }

    /* 7. Newsletter CTA */
    .newsletter-cta {
      background-color: var(--charcoal);
      color: var(--ivory);
      padding: 100px 5%;
      text-align: center;
    }

    .newsletter-cta h2 {
      font-size: clamp(2rem, 3vw, 3rem);
      margin-bottom: 15px;
      color: var(--ivory);
    }

    .newsletter-cta p {
      color: #CCC;
      margin-bottom: 40px;
      font-weight: 300;
      font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    }

    .newsletter-inline-form {
      display: flex;
      max-width: 600px;
      margin: 0 auto;
      border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    }

    .newsletter-inline-form input {
      flex-grow: 1;
      background: transparent;
      border: none;
      color: var(--ivory);
      padding: 15px 10px 15px 0;
      font-family: var(--font-sans);
      font-size: 1rem;
    }

    .newsletter-inline-form input:focus {
      outline: none;
    }

    .newsletter-inline-form button {
      background: transparent;
      border: none;
      color: var(--gold);
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 0.85rem;
      padding: 0 20px;
      cursor: pointer;
      transition: color 0.3s;
    }

    .newsletter-inline-form button:hover {
      color: var(--ivory);
    }

    @media (max-width: 768px) {
      .newsletter-inline-form {
        flex-direction: column;
        border-bottom: none;
        gap: 15px;
      }

      .newsletter-inline-form input {
        border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        padding: 15px;
        text-align: center;
      }

      .newsletter-inline-form button {
        background: var(--gold);
        color: var(--ivory);
        padding: 15px;
        width: 100%;
      }

      .newsletter-inline-form button:hover {
        background: #A38656;
      }
    }

    /* 8. Footer (Consistent with index.ejs) */
    .footer-luxury {
      background-color: var(--charcoal);
      color: var(--ivory);
      padding: 80px 5% 40px 5%;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      /* Slight separation from newsletter */
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 2fr;
      gap: 60px;
      margin-bottom: 60px;
    }

    .footer-col h4 {
      font-family: var(--font-sans);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 30px;
      color: var(--gold);
    }

    .footer-col p,
    .footer-col a {
      color: #999;
      font-size: 0.9rem;
      line-height: 1.8;
      transition: color 0.3s;
    }

    .footer-col a {
      display: block;
      margin-bottom: 15px;
    }

    .footer-col a:hover {
      color: var(--ivory);
    }

    .newsletter-form {
      display: flex;
      margin-top: 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    }

    .newsletter-form input {
      background: transparent;
      border: none;
      color: var(--ivory);
      padding: 10px 0;
      width: 100%;
    }

    .newsletter-form input:focus {
      outline: none;
    }

    .newsletter-form button {
      background: transparent;
      border: none;
      color: var(--gold);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-size: 0.8rem;
      cursor: pointer;
      padding: 0 10px;
    }

    .social-links {
      display: flex;
      gap: 20px;
      margin-top: 30px;
    }

    .social-links a {
      color: var(--ivory);
      font-size: 1.2rem;
    }

    .footer-bottom {
      text-align: center;
      border-top: 1px solid rgba(197, 166, 110, 0.3);
      padding-top: 30px;
      font-size: 0.8rem;
      color: #666;
    }

    @media (max-width: 991px) {
      .footer-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 768px) {
      .footer-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .footer-luxury {
        padding: 60px 5% 30px 5%;
      }
    }
  </style>
</head>

<body>
  <!-- 1. Top Bar -->
  <div class="top-bar">
    Free Worldwide Shipping | Authenticity Guaranteed
  </div>

  <!-- 2. Navigation -->
  <nav class="navbar-luxury">
    <div class="navbar-brand">
      <a href="/">
        <h1>LUXE TIME</h1>
      </a>
    </div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/shope">Shop</a>
      <a href="/shope">Collections</a>
      <a href="/blog" class="active">Blog</a>
      <a href="/contact">Contact</a>
    </div>
    <div class="nav-icons">
      <a href="/shope"><i class="fa-solid fa-magnifying-glass"></i></a>
      <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
      <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>

      <% if (typeof user !=='undefined' && user) { %>
        <a href="/profile" title="Profile">
          <% if (user.image && user.image.length> 0) { %>
            <img src="<%= user.image[0] %>" alt="Profile" class="profile-img-nav">
            <% } else { %>
              <i class="fa-regular fa-user"></i>
              <% } %>
        </a>
        <a href="/logout" title="Logout"><i class="fa-solid fa-right-from-bracket"></i></a>
        <% } else { %>
          <a href="/login" title="Login"><i class="fa-regular fa-user"></i></a>
          <% } %>
    </div>

    <button class="mobile-menu-btn" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
      <i class="fa-solid fa-bars"></i>
    </button>
  </nav>

  <!-- Mobile Menu Offcanvas -->
  <div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu">
    <div class="offcanvas-header border-bottom border-secondary">
      <h5 class="offcanvas-title serif">LUXE TIME</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column text-center mt-5">
      <a href="/">Home</a>
      <a href="/shope">Shop</a>
      <a href="/shope">Collections</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
      <hr class="border-secondary my-4">
      <div class="d-flex justify-content-center gap-4 mt-3">
        <a href="/shope"><i class="fa-solid fa-magnifying-glass"></i></a>
        <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
        <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
        <a href="<%= (typeof user !== 'undefined' && user) ? '/profile' : '/login' %>"><i
            class="fa-regular fa-user"></i></a>
        <% if (typeof user !=='undefined' && user) { %>
          <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i></a>
          <% } %>
      </div>
    </div>
  </div>

  <!-- Page Header -->
  <header class="journal-header">
    <h1 class="serif">The Journal</h1>
    <p>Chronicles of Horology, Craftsmanship, and Style</p>
  </header>

  <!-- Category Filter -->
  <div class="category-filter">
    <div class="category-pill active">All</div>
    <div class="category-pill">Watch Guides</div>
    <div class="category-pill">Brand Stories</div>
    <div class="category-pill">Craftsmanship</div>
    <div class="category-pill">News</div>
  </div>

  <!-- Featured Article -->
  <section class="featured-article">
    <a href="#" class="featured-card">
      <img src="https://images.unsplash.com/photo-1547996160-81dfa63595aa?q=80&w=1887&auto=format&fit=crop"
        alt="The Evolution of the Tourbillon" class="featured-image">
      <div class="featured-overlay"></div>
      <div class="featured-content">
        <span class="category-tag">Craftsmanship</span>
        <h2 class="serif">The Evolution of the Tourbillon: From Pocket Watches to Modern Masterpieces</h2>
        <div class="article-meta">
          <span><i class="fa-regular fa-calendar"></i> October 15, 2024</span>
          <span><i class="fa-regular fa-clock"></i> 8 Min Read</span>
        </div>
        <span class="read-more-link">Read More</span>
      </div>
    </a>
  </section>

  <!-- Article Grid -->
  <section class="journal-grid">
    <!-- Article 1 -->
    <a href="#" class="article-card">
      <div class="article-image-wrapper">
        <img src="https://images.unsplash.com/photo-1523170335258-f5ed11844a49?q=80&w=2080&auto=format&fit=crop"
          alt="Iconic Dive Watches" class="article-image">
      </div>
      <span class="category-tag">Watch Guides</span>
      <h3 class="article-title">Top 5 Iconic Dive Watches Every Collector Should Know</h3>
      <p class="article-excerpt">Discover the history and enduring appeal of the world's most recognizable underwater
        timepieces that defined an era.</p>
      <div class="article-date">October 10, 2024</div>
    </a>

    <!-- Article 2 -->
    <a href="#" class="article-card">
      <div class="article-image-wrapper">
        <img src="https://images.unsplash.com/photo-1612817159949-195b6eb9e31a?q=80&w=2070&auto=format&fit=crop"
          alt="The Art of Enameling" class="article-image">
      </div>
      <span class="category-tag">Brand Stories</span>
      <h3 class="article-title">The Lost Art of Grand Feu Enameling in Modern Horology</h3>
      <p class="article-excerpt">A deep dive into the painstaking process of creating vibrant, everlasting dials using
        techniques unchanged for centuries.</p>
      <div class="article-date">October 05, 2024</div>
    </a>

    <!-- Article 3 -->
    <a href="#" class="article-card">
      <div class="article-image-wrapper">
        <img src="https://images.unsplash.com/photo-1622434641406-a158123450f9?q=80&w=1904&auto=format&fit=crop"
          alt="Geneva Watch Days 2024" class="article-image">
      </div>
      <span class="category-tag">News</span>
      <h3 class="article-title">Highlights from Geneva Watch Days: What You Missed</h3>
      <p class="article-excerpt">An exclusive look at the most exciting releases, unexpected trends, and groundbreaking
        innovations from this year's show.</p>
      <div class="article-date">September 28, 2024</div>
    </a>

    <!-- Article 4 -->
    <a href="#" class="article-card">
      <div class="article-image-wrapper">
        <img src="https://images.unsplash.com/photo-1524592094714-0f0654e20314?q=80&w=1999&auto=format&fit=crop"
          alt="Investing in Vintage" class="article-image">
      </div>
      <span class="category-tag">Watch Guides</span>
      <h3 class="article-title">A Beginner's Guide to Investing in Vintage Timepieces</h3>
      <p class="article-excerpt">Navigating the complexities of the vintage market: what to look for, condition over
        rarity, and avoiding common pitfalls.</p>
      <div class="article-date">September 20, 2024</div>
    </a>

    <!-- Article 5 -->
    <a href="#" class="article-card">
      <div class="article-image-wrapper">
        <img src="https://images.unsplash.com/photo-1508685096489-7aacd43bd3b1?q=80&w=2127&auto=format&fit=crop"
          alt="Mechanical Movements" class="article-image">
      </div>
      <span class="category-tag">Craftsmanship</span>
      <h3 class="article-title">Understanding the Anatomy of a Mechanical Movement</h3>
      <p class="article-excerpt">Breaking down the intricate components that bring a mechanical watch to life, from the
        mainspring to the escapement.</p>
      <div class="article-date">September 12, 2024</div>
    </a>

    <!-- Article 6 -->
    <a href="#" class="article-card">
      <div class="article-image-wrapper">
        <img src="https://images.unsplash.com/photo-1548690312-e3b507d8c110?q=80&w=2070&auto=format&fit=crop"
          alt="Independent Watchmakers" class="article-image">
      </div>
