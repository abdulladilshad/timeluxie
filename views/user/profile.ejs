<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile | <%= user.name %></title>
    <link rel="stylesheet" href="/styles/profile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/styles/account-dashboard.css">
    <style>
        /* Mobile Offcanvas Overrides */
        .offcanvas {
            background-color: #1A1A1A !important;
            color: #F5F1EB !important;
        }
        .offcanvas .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
        }
        .offcanvas a {
            color: #F5F1EB !important;
            text-decoration: none;
        }
        .offcanvas-body > a {
            font-family: 'Marcellus', serif;
            font-size: 1.5rem;
            margin-bottom: 20px;
            display: block;
        }
        .offcanvas a:hover {
            color: #d4af37 !important;
        }
    </style>
</head>

<body>
    
    <!-- 1. Top Bar -->
    <div class="top-bar">
        Free Worldwide Shipping | Authenticity Guaranteed
    </div>

    <!-- 2. Navigation -->
    <nav class="navbar-luxury">
        <div class="navbar-brand">
            <a href="/"><h1>LUXE TIME</h1></a>
        </div>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/shope">Shop</a>
            <a href="/shope">Collections</a>
            <a href="/blog">Blog</a>
            <a href="/contact">Contact</a>
        </div>
        <div class="nav-icons">
            <a href="/shope" title="Search"><i class="fa-solid fa-magnifying-glass"></i></a>
            <a href="/wishlist" title="Wishlist"><i class="fa-regular fa-heart"></i></a>
            <a href="/cart" title="Cart"><i class="fa-solid fa-cart-shopping"></i></a>
            <a href="javascript:void(0)" title="Share Referral" onclick="shareReferral()">
                <i class="fa-brands fa-whatsapp" style="color: #25D366;"></i>
            </a>
            <% if (typeof user !== 'undefined' && user) { %>
                <a href="/profile" title="Profile">
                    <% if (user.image && user.image.length > 0) { %>
                        <img src="<%= user.image[0] %>" alt="Profile" class="profile-img-nav">
                    <% } else { %>
                        <i class="fa-regular fa-user"></i>
                    <% } %>
                </a>
                <a href="/logout" title="Logout"><i class="fa-solid fa-right-from-bracket"></i></a>
            <% } else { %>
                <a href="/login" title="Login"><i class="fa-regular fa-user"></i></a>
            <% } %>
        </div>
        
        <button class="mobile-menu-btn" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
            <i class="fa-solid fa-bars"></i>
        </button>
    </nav>

    <!-- Mobile Menu Offcanvas -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu">
        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title serif">LUXE TIME</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column text-center mt-5">
            <a href="/">Home</a>
            <a href="/shope">Shop</a>
            <a href="/shope">Collections</a>
            <a href="/blog">Blog</a>
            <a href="/contact">Contact</a>
            <a href="/cart">Cart</a>
            <a href="/wishlist">Wishlist</a>
            <hr class="border-secondary my-4">
            <div class="d-flex justify-content-center gap-4 mt-3">
                <a href="/shope"><i class="fa-solid fa-magnifying-glass"></i></a>
                <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
                <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
                <a href="<%= (typeof user !== 'undefined' && user) ? '/profile' : '/login' %>"><i class="fa-regular fa-user"></i></a>
                <% if (typeof user !== 'undefined' && user) { %>
                    <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i></a>
                <% } %>
            </div>
        </div>
    </div>

    <div class="account-container">
        
        <div class="account-sidebar">
            <div class="sidebar-greeting">
                <span class="serif">Welcome</span>
            </div>
            <nav class="sidebar-nav">
                <a href="/orders" class="sidebar-link">
                    <i class="fas fa-shopping-bag"></i>
                    <span>My Orders</span>
                </a>
                <a href="/profile" class="sidebar-link active">
                    <i class="fas fa-user"></i>
                    <span>Personal Information</span>
                </a>
                <a href="/address" class="sidebar-link">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>Saved Addresses</span>
                </a>
                <a href="/wishlist" class="sidebar-link">
                    <i class="fas fa-heart"></i>
                    <span>Wishlist</span>
                </a>
                <a href="/wallet" class="sidebar-link">
                    <i class="fas fa-wallet"></i>
                    <span>Payment Methods</span>
                </a>
                <a href="/change-password" class="sidebar-link">
                    <i class="fas fa-cog"></i>
                    <span>Account Settings</span>
                </a>
                <a href="/logout" class="sidebar-link text-danger">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Log Out</span>
                </a>
            </nav>
        </div>

        <div class="profile-card account-content glass-card">
            <div class="profile-header">
                <div class="profile-image">
                    <img id="profilePreview" src="<%=user.image || '/images/default-avatar.png' %>"
                        alt="Profile Picture">

                    <% if (!user.googleId) { %>
                        <div class="image-upload">
                            <label for="avatar" class="upload-label">
                                <i class="fas fa-camera"></i>
                            </label>
                            <input type="file" id="avatar" name="avatar" accept="image/*" style="display: none;">
                        </div>
                        <% } %>
                </div>
                <h1>
                    <%= user.name || user.email %>
                </h1>
                <p class="email"><i class="fas fa-envelope"></i>
                    <%= user.email %>
                </p>
            </div>

            <div class="profile-content">
                <form id="profileForm" class="profile-form">
                    <div class="form-group">
                        <label for="name">
                            <i class="fas fa-user"></i> Full Name
                        </label>
                        <input type="text" id="name" name="name" value="<%= user.name %>" required>
                    </div>

                    <div class="form-group">
                        <label for="email">
                            <i class="fas fa-envelope"></i> Email Address
                        </label>
                        <input type="email" id="email" name="email" value="<%= user.email %>" readonly required>
                    </div>

                  
                    <div class="form-group referral-section">
                        <label>
                            <i class="fas fa-gift"></i> Your Referral Code
                        </label>
                        <div class="referral-code-container">
                            <input type="text" id="referralCode" value="<%= user.referralCode || 'LUXE' + user._id?.toString().substring(0, 6) %>" readonly>
                            <button type="button" class="copy-btn" onclick="copyReferralCode()" title="Copy Code">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                        <p class="referral-info">Share this code with friends and earn rewards!</p>
                    </div>

                    <button type="submit" class="update-btn gold-btn" style="width: 100%;">
                        <i class="fas fa-save"></i> Update Profile
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('profileForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData();
            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const avatarInput = document.getElementById('avatar');


            
            if (!name.trim()) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Validation Error',
                    text: 'Please enter your name'
                });
                return;
            }

            formData.append('name', name);
            formData.append('email', email);


            
            if (avatarInput && avatarInput.files[0]) {
                const file = avatarInput.files[0];
                
                
                const validImageTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif'];
                if (!validImageTypes.includes(file.type)) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid File Type',
                        text: 'Please upload only image files (JPEG, PNG, JPG, GIF)'
                    });
                    return;
                }


                
                const maxSize = 5 * 1024 * 1024; 
                if (file.size > maxSize) {
                    Swal.fire({
                        icon: 'error',
                        title: 'File Too Large',
                        text: 'Image size should be less than 5MB'
                    });
                    return;
                }

                formData.append('avatar', file);
            }

            try {
                const response = await fetch('/profile/update', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const data = await response.json();
                    document.querySelector('.profile-header h1').textContent = data.name;
                    if (data.avatar) {
                        document.getElementById('profilePreview').src = data.avatar;
                    }
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: 'Profile updated successfully!',
                        showConfirmButton: false,
                        timer: 1500
                    });
                } else {
                    const errorData = await response.json();
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: errorData.message || 'Failed to update profile'
                    });
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred while updating profile'
                });
            }
        });

        
        if (document.getElementById('avatar')) {
            document.getElementById('avatar').addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {

                    
                    const validImageTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif'];
                    if (!validImageTypes.includes(file.type)) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Invalid File Type',
                            text: 'Please upload only image files (JPEG, PNG, JPG, GIF)'
                        });

                        this.value = ''; 
                        return;
                    }

                    
                    const maxSize = 5 * 1024 * 1024; 
                    if (file.size > maxSize) {
                        Swal.fire({
                            icon: 'error',
                            title: 'File Too Large',
                            text: 'Image size should be less than 5MB'
                        });

                        this.value = ''; 
                        return;
                    }

                    
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        document.getElementById('profilePreview').src = e.target.result;
                    }
                    reader.readAsDataURL(file);
                }
            });
        }

        
        function copyReferralCode() {
            const referralCode = document.getElementById('referralCode');
            referralCode.select();
            document.execCommand('copy');
            
            Swal.fire({
                icon: 'success',
                title: 'Copied!',
                text: 'Referral code copied to clipboard',
                showConfirmButton: false,
                timer: 1500
            });
        }
        
        
        function shareReferral() {
            const referralCode = document.getElementById('referralCode').value;
            const message = encodeURIComponent(`Hey! Check out LUXE TIME, a premium watch store. Use my referral code ${referralCode} to get special discount on your first purchase! Visit: ${window.location.origin}`);
            const whatsappUrl = `https://api.whatsapp.com/send?text=${message}`;
            window.open(whatsappUrl, '_blank');
        }
    </script>
</body>

</html>