<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile | <%= user.name %></title>
    <link rel="stylesheet" href="/styles/profile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/styles/account-dashboard.css">
</head>

<body>
    
    <nav class="navbar navbar-expand-lg fixed-top bg-white">
        <div class="container">
            
            <a class="navbar-brand" href="/">
                LUXE TIME 
                <span class="brand-dot"></span>
            </a>

            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="toggler-icon"></span>
            </button>

            
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav mx-auto text-uppercase">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/shope">Shop</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/men">Men</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/women">Women</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/limited-edition">Limited Edition</a>
                    </li>
                </ul>
            </div>

           
            <div class="nav-icons">
                <a href="/search" class="nav-icon" title="Search">
                    <i class="fas fa-search"></i>
                </a>
                <a href="/wishlist" class="nav-icon" title="Wishlist">
                    <i class="fas fa-heart"></i>
                </a>
                <a href="/cart" class="nav-icon" title="Cart">
                    <i class="fas fa-shopping-cart"></i>
                </a>
                <a href="/orders" class="nav-icon" title="Account">
                    <i class="fas fa-user"></i>
                </a>
                <a href="javascript:void(0)" class="nav-icon" title="Share Referral" onclick="shareReferral()">
                    <i class="fab fa-whatsapp" style="color: #25D366;"></i>
                    <span class="icon-badge">Share</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="account-container">
        
        <div class="account-sidebar">
            <div class="sidebar-greeting">
                <span class="serif">Welcome</span>
            </div>
            <nav class="sidebar-nav">
                <a href="/orders" class="sidebar-link">
                    <i class="fas fa-shopping-bag"></i>
                    <span>My Orders</span>
                </a>
                <a href="/profile" class="sidebar-link active">
                    <i class="fas fa-user"></i>
                    <span>Personal Information</span>
                </a>
                <a href="/address" class="sidebar-link">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>Saved Addresses</span>
                </a>
                <a href="/wishlist" class="sidebar-link">
                    <i class="fas fa-heart"></i>
                    <span>Wishlist</span>
                </a>
                <a href="/wallet" class="sidebar-link">
                    <i class="fas fa-wallet"></i>
                    <span>Payment Methods</span>
                </a>
                <a href="/change-password" class="sidebar-link">
                    <i class="fas fa-cog"></i>
                    <span>Account Settings</span>
                </a>
                <a href="/logout" class="sidebar-link text-danger">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Log Out</span>
                </a>
            </nav>
        </div>

        <div class="profile-card account-content glass-card">
            <div class="profile-header">
                <div class="profile-image">
                    <img id="profilePreview" src="<%=user.image || '/images/default-avatar.png' %>"
                        alt="Profile Picture">

                    <% if (!user.googleId) { %>
                        <div class="image-upload">
                            <label for="avatar" class="upload-label">
                                <i class="fas fa-camera"></i>
                            </label>
                            <input type="file" id="avatar" name="avatar" accept="image/*" style="display: none;">
                        </div>
                        <% } %>
                </div>
                <h1>
                    <%= user.name || user.email %>
                </h1>
                <p class="email"><i class="fas fa-envelope"></i>
                    <%= user.email %>
                </p>
            </div>

            <div class="profile-content">
                <form id="profileForm" class="profile-form">
                    <div class="form-group">
                        <label for="name">
                            <i class="fas fa-user"></i> Full Name
                        </label>
                        <input type="text" id="name" name="name" value="<%= user.name %>" required>
                    </div>

                    <div class="form-group">
                        <label for="email">
                            <i class="fas fa-envelope"></i> Email Address
                        </label>
                        <input type="email" id="email" name="email" value="<%= user.email %>" readonly required>
                    </div>

                  
                    <div class="form-group">
                        <label>
                            <i class="fas fa-gift"></i> Your Referral Code
                        </label>
                        <div class="referral-code-container">
                            <input type="text" id="referralCode" value="<%= user.referralCode || 'LUXE' + user._id?.toString().substring(0, 6) %>" readonly>
                            <button type="button" class="copy-btn" onclick="copyReferralCode()">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                        <p class="referral-info">Share this code with friends and earn rewards!</p>
                    </div>

                    <button type="submit" class="update-btn gold-btn" style="width: 100%;">
                        <i class="fas fa-save"></i> Update Profile
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('profileForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData();
            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const avatarInput = document.getElementById('avatar');


            
            if (!name.trim()) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Validation Error',
                    text: 'Please enter your name'
                });
                return;
            }

            formData.append('name', name);
            formData.append('email', email);


            
            if (avatarInput && avatarInput.files[0]) {
                const file = avatarInput.files[0];
                
                
                const validImageTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif'];
                if (!validImageTypes.includes(file.type)) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid File Type',
                        text: 'Please upload only image files (JPEG, PNG, JPG, GIF)'
                    });
                    return;
                }


                
                const maxSize = 5 * 1024 * 1024; 
                if (file.size > maxSize) {
                    Swal.fire({
                        icon: 'error',
                        title: 'File Too Large',
                        text: 'Image size should be less than 5MB'
                    });
                    return;
                }

                formData.append('avatar', file);
            }

            try {
                const response = await fetch('/profile/update', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const data = await response.json();
                    document.querySelector('.profile-header h1').textContent = data.name;
                    if (data.avatar) {
                        document.getElementById('profilePreview').src = data.avatar;
                    }
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: 'Profile updated successfully!',
                        showConfirmButton: false,
                        timer: 1500
                    });
                } else {
                    const errorData = await response.json();
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: errorData.message || 'Failed to update profile'
                    });
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred while updating profile'
                });
            }
        });

        
        if (document.getElementById('avatar')) {
            document.getElementById('avatar').addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {

                    
                    const validImageTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif'];
                    if (!validImageTypes.includes(file.type)) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Invalid File Type',
                            text: 'Please upload only image files (JPEG, PNG, JPG, GIF)'
                        });

                        this.value = ''; 
                        return;
                    }

                    
                    const maxSize = 5 * 1024 * 1024; 
                    if (file.size > maxSize) {
                        Swal.fire({
                            icon: 'error',
                            title: 'File Too Large',
                            text: 'Image size should be less than 5MB'
                        });

                        this.value = ''; 
                        return;
                    }

                    
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        document.getElementById('profilePreview').src = e.target.result;
                    }
                    reader.readAsDataURL(file);
                }
            });
        }

        
        function copyReferralCode() {
            const referralCode = document.getElementById('referralCode');
            referralCode.select();
            document.execCommand('copy');
            
            Swal.fire({
                icon: 'success',
                title: 'Copied!',
                text: 'Referral code copied to clipboard',
                showConfirmButton: false,
                timer: 1500
            });
        }
        
        
        function shareReferral() {
            const referralCode = document.getElementById('referralCode').value;
            const message = encodeURIComponent(`Hey! Check out LUXE TIME, a premium watch store. Use my referral code ${referralCode} to get special discount on your first purchase! Visit: ${window.location.origin}`);
            const whatsappUrl = `https://api.whatsapp.com/send?text=${message}`;
            window.open(whatsappUrl, '_blank');
        }
    </script>
</body>

</html>