<!DOCTYPE html>
<html lang="en">
<head>
  <title>LUXE TIME - Luxury Watch collections</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">

  <style>
    :root {
      --ivory: #F5F1EB;
      --charcoal: #1A1A1A;
      --gold: #C5A66E;
      --warm-gray: #8C8C8C;
      --font-serif: 'Playfair Display', serif;
      --font-sans: 'Inter', sans-serif;
    }

    body {
      background-color: var(--ivory);
      color: var(--charcoal);
      font-family: var(--font-sans);
      margin: 0;
      padding: 0;
    }

    h1, h2, h3, h4, h5, h6, .serif {
      font-family: var(--font-serif);
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    /* 1. Top Bar */
    .top-bar {
      background-color: var(--charcoal);
      color: var(--ivory);
      text-align: center;
      padding: 8px 0;
      font-size: 0.8rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      font-weight: 300;
    }

    /* 2. Navigation */
    .navbar-luxury {
      background-color: var(--ivory);
      padding: 20px 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(26,26,26,0.1);
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    
    .navbar-brand h1 {
      margin: 0;
      font-size: 1.8rem;
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--charcoal);
    }

    .nav-links {
      display: flex;
      gap: 30px;
    }

    .nav-links a {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 500;
      position: relative;
      transition: color 0.3s;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      width: 0;
      height: 1px;
      bottom: -4px;
      left: 0;
      background-color: var(--gold);
      transition: width 0.3s;
    }

    .nav-links a:hover {
      color: var(--gold);
    }

    .nav-links a:hover::after {
      width: 100%;
    }

    .nav-icons {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .nav-icons a {
      font-size: 1.1rem;
      transition: color 0.3s;
    }

    .nav-icons a:hover {
      color: var(--gold);
    }
    
    .profile-img-nav {
      width: 25px;
      height: 25px;
      border-radius: 50%;
      object-fit: cover;
    }

    /* Mobile Menu */
    .mobile-menu-btn {
      display: none;
      font-size: 1.5rem;
      cursor: pointer;
      background: none;
      border: none;
      color: var(--charcoal);
    }

    @media (max-width: 991px) {
      .nav-links { display: none; }
      .nav-icons { display: none; }
      .mobile-menu-btn { display: block; }
    }

    /* 3. Hero Section */
    .hero {
      height: 85vh;
      background-image: linear-gradient(rgba(26,26,26,0.4), rgba(26,26,26,0.7)), url('https://images.unsplash.com/photo-1523170335258-f5ed11844a49?q=80&w=2080&auto=format&fit=crop');
      background-size: cover;
      background-position: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      color: var(--ivory);
      padding: 0 20px;
    }

    .hero h2 {
      font-size: 4rem;
      font-weight: 400;
      margin-bottom: 30px;
      max-width: 800px;
      line-height: 1.2;
    }

    .btn-gold {
      background-color: var(--gold);
      color: var(--ivory);
      padding: 15px 40px;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      border: none;
      transition: background-color 0.3s, transform 0.3s;
      display: inline-block;
    }

    .btn-gold:hover {
      background-color: #A38656;
      transform: translateY(-2px);
      color: var(--ivory);
    }

    /* 4. Brand Promise Strip */
    .promises {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      padding: 60px 5%;
      background-color: var(--ivory);
      border-bottom: 1px solid rgba(26,26,26,0.1);
      text-align: center;
    }

    .promise-item i {
      font-size: 1.5rem;
      color: var(--gold);
      margin-bottom: 15px;
    }

    .promise-item p {
      font-size: 0.9rem;
      color: var(--warm-gray);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin: 0;
    }

    @media (max-width: 768px) {
      .promises { grid-template-columns: 1fr; gap: 40px; }
    }

    /* 5. Featured Collections */
    .collections {
      padding: 100px 5%;
    }

    .section-title {
      text-align: center;
      font-size: 2.5rem;
      margin-bottom: 60px;
      color: var(--charcoal);
    }

    .collections-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }

    .collection-card {
      height: 500px;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
      padding: 40px;
      transition: transform 0.5s;
    }

    .collection-card:hover {
      transform: translateY(-10px);
    }

    .collection-bg {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background-size: cover;
      background-position: center;
      transition: transform 0.8s;
      z-index: 1;
    }

    .collection-card:hover .collection-bg {
      transform: scale(1.05);
    }

    .collection-overlay {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: linear-gradient(to top, rgba(26,26,26,0.8), transparent);
      z-index: 2;
    }

    .collection-content {
      position: relative;
      z-index: 3;
      color: var(--ivory);
      width: 100%;
    }

    .collection-content h3 {
      font-size: 2rem;
      margin-bottom: 15px;
    }

    .collection-link {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      border-bottom: 1px solid var(--gold);
      padding-bottom: 5px;
      display: inline-block;
      transition: color 0.3s, border-color 0.3s;
    }

    .collection-link:hover {
      color: var(--gold);
    }

    @media (max-width: 991px) {
      .collections-grid { grid-template-columns: 1fr; }
      .collection-card { height: 400px; }
    }

    /* 6. Signature Product Spotlight */
    .spotlight {
      background-color: var(--charcoal);
      color: var(--ivory);
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .spotlight-img {
      background-size: cover;
      background-position: center;
      min-height: 600px;
    }

    .spotlight-content {
      padding: 100px 10%;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .spotlight-subtitle {
      color: var(--gold);
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 0.8rem;
      margin-bottom: 20px;
    }

    .spotlight-content h3 {
      font-size: 3rem;
      margin-bottom: 20px;
    }

    .spotlight-desc {
      color: #CCC;
      line-height: 1.8;
      margin-bottom: 40px;
      font-weight: 300;
    }

    .spotlight-price {
      font-size: 1.5rem;
      font-weight: 500;
      margin-bottom: 30px;
    }

    @media (max-width: 991px) {
      .spotlight { grid-template-columns: 1fr; }
      .spotlight-img { min-height: 400px; }
      .spotlight-content { padding: 60px 5%; }
    }

    /* 7. Editorial Section */
    .editorial {
      height: 60vh;
      background-image: linear-gradient(rgba(26,26,26,0.3), rgba(26,26,26,0.3)), url('https://images.unsplash.com/photo-1548690312-e3b507d8c110?q=80&w=2070&auto=format&fit=crop');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
      color: var(--ivory);
    }

    .editorial h2 {
      font-size: 3.5rem;
      margin-bottom: 30px;
    }

    /* 8. New Arrivals Carousel */
    .arrivals {
      padding: 100px 0;
      overflow: hidden;
    }

    .arrivals-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .carousel-container {
      display: flex;
      overflow-x: auto;
      gap: 30px;
      padding: 0 5% 40px 5%;
      scrollbar-width: none;
    }

    .carousel-container::-webkit-scrollbar {
      display: none;
    }

    .product-card {
      min-width: 300px;
      flex-shrink: 0;
    }

    .product-img-wrapper {
      background-color: #fff;
      padding: 40px;
      margin-bottom: 20px;
      transition: transform 0.5s;
      border-radius: 4px;
    }

    .product-card:hover .product-img-wrapper {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .product-img-wrapper img {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
      object-fit: contain;
    }

    .product-brand {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--warm-gray);
      margin-bottom: 5px;
    }

    .product-name {
      font-size: 1.2rem;
      margin-bottom: 10px;
      color: var(--charcoal);
    }

    .product-price {
      font-size: 1rem;
      font-weight: 500;
      color: var(--gold);
    }

    /* 9. Footer */
    .footer-luxury {
      background-color: var(--charcoal);
      color: var(--ivory);
      padding: 80px 5% 40px 5%;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 2fr;
      gap: 60px;
      margin-bottom: 60px;
    }

    .footer-col h4 {
      font-family: var(--font-sans);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 30px;
      color: var(--gold);
    }

    .footer-col p, .footer-col a {
      color: #999;
      font-size: 0.9rem;
      line-height: 1.8;
      transition: color 0.3s;
    }

    .footer-col a {
      display: block;
      margin-bottom: 15px;
    }

    .footer-col a:hover {
      color: var(--ivory);
    }

    .newsletter-form {
      display: flex;
      margin-top: 20px;
      border-bottom: 1px solid rgba(255,255,255,0.2);
    }

    .newsletter-form input {
      background: transparent;
      border: none;
      color: var(--ivory);
      padding: 10px 0;
      width: 100%;
    }

    .newsletter-form input:focus {
      outline: none;
    }

    .newsletter-form button {
      background: transparent;
      border: none;
      color: var(--gold);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-size: 0.8rem;
      cursor: pointer;
      padding: 0 10px;
    }

    .social-links {
      display: flex;
      gap: 20px;
      margin-top: 30px;
    }

    .social-links a {
      color: var(--ivory);
      font-size: 1.2rem;
    }

    .footer-bottom {
      text-align: center;
      border-top: 1px solid rgba(197, 166, 110, 0.3); /* Thin gold divider */
      padding-top: 30px;
      font-size: 0.8rem;
      color: #666;
    }

    @media (max-width: 991px) {
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      .footer-grid { grid-template-columns: 1fr; gap: 40px; }
      
      /* Typography & Spacing Fixes for Mobile */
      .hero h2 {
        font-size: 2.5rem;
        margin-bottom: 20px;
      }
      .promises {
        padding: 40px 5%;
        gap: 30px;
      }
      .collections {
        padding: 60px 5%;
      }
      .section-title {
        font-size: 2rem;
        margin-bottom: 40px;
      }
      .spotlight-content h3 {
        font-size: 2rem;
      }
      .editorial h2 {
        font-size: 2rem;
      }
      .arrivals {
        padding: 60px 0;
      }
      .product-card {
        min-width: 250px;
      }
      .product-name {
        font-size: 1rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .footer-luxury {
        padding: 60px 5% 30px 5%;
      }
    }
    
    /* Mobile Offcanvas Overrides */
    .offcanvas {
        background-color: var(--charcoal);
        color: var(--ivory);
    }
    .offcanvas .btn-close {
        filter: invert(1) grayscale(100%) brightness(200%);
    }
    .offcanvas a {
        color: var(--ivory);
        font-family: var(--font-serif);
        font-size: 1.5rem;
        margin-bottom: 20px;
        display: block;
    }
    .offcanvas a:hover {
        color: var(--gold);
    }
  </style>
</head>

<body>
  <!-- 1. Top Bar -->
  <div class="top-bar">
    Free Worldwide Shipping | Authenticity Guaranteed
  </div>

  <!-- 2. Navigation -->
  <nav class="navbar-luxury">
    <div class="navbar-brand">
      <a href="/"><h1>LUXE TIME</h1></a>
    </div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/shope">Shop</a>
      <a href="/shope">Collections</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
    </div>
    <div class="nav-icons">
      <a href="/shope"><i class="fa-solid fa-magnifying-glass"></i></a>
      <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
      <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
      
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/profile" title="Profile">
          <% if (user.image && user.image.length > 0) { %>
            <img src="<%= user.image[0] %>" alt="Profile" class="profile-img-nav">
          <% } else { %>
            <i class="fa-regular fa-user"></i>
          <% } %>
        </a>
        <a href="/logout" title="Logout"><i class="fa-solid fa-right-from-bracket"></i></a>
      <% } else { %>
        <a href="/login" title="Login"><i class="fa-regular fa-user"></i></a>
      <% } %>
    </div>
    
    <button class="mobile-menu-btn" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
      <i class="fa-solid fa-bars"></i>
    </button>
  </nav>

  <!-- Mobile Menu Offcanvas -->
  <div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu">
    <div class="offcanvas-header border-bottom border-secondary">
      <h5 class="offcanvas-title serif">LUXE TIME</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column text-center mt-5">
      <a href="/">Home</a>
      <a href="/shope">Shop</a>
      <a href="/shope">Collections</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
      <hr class="border-secondary my-4">
      <div class="d-flex justify-content-center gap-4 mt-3">
        <a href="/shope"><i class="fa-solid fa-magnifying-glass"></i></a>
        <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
        <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
        <a href="<%= (typeof user !== 'undefined' && user) ? '/profile' : '/login' %>"><i class="fa-regular fa-user"></i></a>
        <% if (typeof user !== 'undefined' && user) { %>
            <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i></a>
        <% } %>
      </div>
    </div>
  </div>

  <!-- 3. Hero Section -->
  <section class="hero">
    <h2 class="serif">Timeless Elegance, Redefined.</h2>
    <a href="/shope" class="btn-gold">Explore the Collection</a>
  </section>

  <!-- 4. Brand Promise Strip -->
  <section class="promises">
    <div class="promise-item">
      <i class="fa-solid fa-check-circle"></i>
      <p>Swiss Certified</p>
    </div>
    <div class="promise-item">
      <i class="fa-solid fa-box-open"></i>
      <p>Free Returns</p>
    </div>
    <div class="promise-item">
      <i class="fa-solid fa-shield-halved"></i>
      <p>2-Year Warranty</p>
    </div>
  </section>

  <!-- 5. Featured Collections -->
  <section class="collections">
    <h2 class="section-title serif">Our Collections</h2>
    <div class="collections-grid">
      <!-- We will limit to 3 categories -->
      <% 
        const displayCategories = categories && categories.length > 0 ? categories.slice(0, 3) : [];
        const bgImages = [
            'https://images.unsplash.com/photo-1622434641406-a158123450f9?q=80&w=1904&auto=format&fit=crop',
            'https://images.unsplash.com/photo-1547996160-81dfa63595aa?q=80&w=1887&auto=format&fit=crop',
            'https://images.unsplash.com/photo-1612817159949-195b6eb9e31a?q=80&w=2070&auto=format&fit=crop'
        ];
      %>
      <% displayCategories.forEach((category, index) => { %>
      <div class="collection-card">
        <div class="collection-bg" style="background-image: url('<%= bgImages[index % bgImages.length] %>');"></div>
        <div class="collection-overlay"></div>
        <div class="collection-content">
          <h3 class="serif"><%= category.name %></h3>
          <a href="/shope?category=<%= category._id %>" class="collection-link">View Collection</a>
        </div>
      </div>
      <% }) %>
    </div>
  </section>

  <!-- 6. Signature Product Spotlight -->
  <% if (products && products.length > 0) { 
      const spotlight = products[0]; 
      const spotlightImage = spotlight.imagePaths && spotlight.imagePaths.length > 0 ? '/' + spotlight.imagePaths[0].replace(/\\/g, '/') : 'https://images.unsplash.com/photo-1524592094714-0f0654e20314?q=80&w=1999&auto=format&fit=crop';
  %>
  <section class="spotlight">
    <div class="spotlight-img" style="background-image: url('<%= spotlightImage %>');"></div>
    <div class="spotlight-content">
      <div class="spotlight-subtitle">Signature Piece</div>
      <h3 class="serif"><%= spotlight.productName %></h3>
      <p class="spotlight-desc"><%= spotlight.description || "Experience the pinnacle of watchmaking craftsmanship. A blend of heritage design and modern engineering, created for those who appreciate the finer things." %></p>
      <div class="spotlight-price">$<%= spotlight.price.toLocaleString() %></div>
      <div>
        <a href="/product/<%= spotlight._id %>" class="btn-gold">Shop Now</a>
      </div>
    </div>
  </section>
  <% } %>

  <!-- 7. Editorial Section -->
  <section class="editorial">
    <div>
      <h2 class="serif">The Art of Horology</h2>
      <a href="/blog" class="btn-gold" style="background-color: transparent; border: 1px solid var(--ivory);">Read Our Story</a>
    </div>
  </section>

  <!-- 8. New Arrivals Carousel -->
  <section class="arrivals">
    <div class="arrivals-header">
      <h2 class="section-title serif" style="margin-bottom: 10px;">New Arrivals</h2>
      <p style="color: var(--warm-gray); letter-spacing: 1px; text-transform: uppercase; font-size: 0.85rem;">Discover our latest timepieces</p>
    </div>
    
    <div class="carousel-container">
      <% if (products && products.length > 0) { %>
        <% products.slice(0, 6).forEach(product => { 
            const brand = product.productName.split(' ')[0]; // Extract first word as brand
            const image = product.imagePaths && product.imagePaths.length > 0 ? '/' + product.imagePaths[0].replace(/\\/g, '/') : '';
        %>
        <div class="product-card">
          <a href="/product/<%= product._id %>">
            <div class="product-img-wrapper">
              <img src="<%= image %>" alt="<%= product.productName %>">
            </div>
            <div class="product-brand"><%= brand %></div>
            <div class="product-name serif"><%= product.productName %></div>
            <div class="product-price">$<%= product.price.toLocaleString() %></div>
          </a>
        </div>
        <% }) %>
      <% } else { %>
        <p class="text-center w-100" style="color: var(--warm-gray);">No products available at the moment.</p>
      <% } %>
    </div>
  </section>

  <!-- 9. Footer -->
  <footer class="footer-luxury">
    <div class="footer-grid">
      <div class="footer-col">
        <h2 class="serif" style="color: var(--ivory); margin-bottom: 20px;">LUXE TIME</h2>
        <p>Curators of fine timepieces. We believe that a watch is more than an accessory; it is a legacy passed down through generations. Authenticity and excellence guaranteed.</p>
        <div class="social-links">
          <a href="#"><i class="fa-brands fa-instagram"></i></a>
          <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
          <a href="#"><i class="fa-brands fa-twitter"></i></a>
          <a href="#"><i class="fa-brands fa-pinterest-p"></i></a>
        </div>
      </div>
      <div class="footer-col">
        <h4>Customer Care</h4>
        <a href="/contact">Contact Us</a>
        <a href="#">Shipping & Returns</a>
        <a href="#">Warranty</a>
        <a href="#">FAQ</a>
        <a href="#">Watch Care Guide</a>
      </div>
      <div class="footer-col">
        <h4>Quick Links</h4>
        <a href="/shope">Shop All</a>
        <a href="/shope">New Arrivals</a>
        <a href="#">Pre-Owned</a>
        <a href="/blog">The Journal</a>
        <a href="#">Our Story</a>
      </div>
      <div class="footer-col">
        <h4>Newsletter</h4>
        <p>Subscribe to receive updates, access to exclusive deals, and more.</p>
        <form class="newsletter-form">
          <input type="email" placeholder="ENTER YOUR EMAIL" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> Luxe Time World. All Rights Reserved. Designed with elegance.</p>
    </div>
  </footer>

