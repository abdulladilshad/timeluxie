<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Wishlist | LUXE TIME</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --gold: #d4af37;
            --gold-hover: #b5952f;
            --warm-gray: #8c8c8c;
            --dark: #1a1a1a;
            --light-bg: #fdfbf7;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);
            min-height: 100vh;
            color: var(--dark);
        }

        .serif {
            font-family: 'Marcellus', serif;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.7);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
            border-radius: 16px;
        }

        /* Navbar */
        .top-bar {
            background-color: var(--dark); color: var(--light-bg); text-align: center;
            padding: 8px 0; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; font-weight: 300;
        }
        .navbar-luxury {
            background-color: rgba(255, 255, 255, 0.95); padding: 20px 5%; display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid rgba(26,26,26,0.1); position: sticky; top: 0; z-index: 1000; backdrop-filter: blur(10px);
        }
        .navbar-brand h1 { margin: 0; font-size: 1.8rem; font-family: 'Marcellus', serif; color: var(--dark); }
        .nav-links { display: flex; gap: 30px; }
        .nav-links a { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 500; position: relative; transition: color 0.3s; text-decoration: none; color: var(--dark); }
        .nav-links a::after { content: ''; position: absolute; width: 0; height: 1px; bottom: -4px; left: 0; background-color: var(--gold); transition: width 0.3s; }
        .nav-links a:hover { color: var(--gold); }
        .nav-links a:hover::after { width: 100%; }
        .nav-icons { display: flex; gap: 20px; align-items: center; }
        .nav-icons a { font-size: 1.1rem; transition: color 0.3s; cursor: pointer; color: var(--dark); text-decoration: none; position: relative; }
        .nav-icons a:hover { color: var(--gold); }
        .profile-img-nav { width: 25px; height: 25px; border-radius: 50%; object-fit: cover; }
        .mobile-menu-btn { display: none; font-size: 1.5rem; cursor: pointer; background: none; border: none; color: var(--dark); }

        /* Search Input Overlay */
        .search-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(26,26,26,0.95);
            z-index: 1100; display: none; justify-content: center; align-items: center; flex-direction: column;
        }
        .search-overlay.active { display: flex; }
        .search-box-large { width: 80%; max-width: 600px; border: none; border-bottom: 2px solid var(--gold); background: transparent; color: var(--light-bg); font-size: 2rem; padding: 10px 0; outline: none; text-align: center; font-family: 'Marcellus', serif; }
        .search-box-large::placeholder { color: rgba(253,251,247,0.5); }
        .close-search { position: absolute; top: 30px; right: 40px; color: var(--light-bg); font-size: 2rem; cursor: pointer; }

        /* Header */
        .page-header {
            display: flex;
            align-items: baseline;
            gap: 15px;
            margin: 40px 0 30px;
        }
        .page-header h1 {
            font-size: 2.5rem;
            margin: 0;
            color: var(--dark);
        }
        .item-count {
            color: var(--warm-gray);
            font-size: 1.1rem;
            font-weight: 400;
        }

        /* Wishlist Grid */
        .wishlist-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
            margin-bottom: 50px;
        }
        .wishlist-card {
            padding: 20px;
            text-align: center;
            display: flex;
            flex-direction: column;
            position: relative;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .wishlist-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        }
        
        .heart-icon {
            position: absolute;
            top: 20px;
            right: 20px;
            color: var(--gold);
            font-size: 1.2rem;
        }
        
        .product-img {
            width: 100%;
            height: 250px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 20px;
            background: #fff;
        }
        
        .product-brand {
            font-variant: small-caps;
            color: var(--warm-gray);
            font-size: 0.85rem;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }
        
        .product-name {
            font-size: 1.2rem;
            color: var(--dark);
            margin-bottom: 10px;
            flex-grow: 1; /* Pushes bottom elements down */
        }
        
        .product-price {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 20px;
        }

        /* Buttons */
        .btn-outline-gold {
            background: transparent;
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 10px 15px;
            border-radius: 6px;
            font-weight: 500;
            transition: all 0.3s;
            width: 100%;
            margin-bottom: 15px;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
        }
        .btn-outline-gold:hover {
            background: var(--gold);
            color: white;
        }
        
        .btn-remove-link {
            background: none;
            border: none;
            color: var(--warm-gray);
            font-size: 0.85rem;
            text-decoration: underline;
            transition: color 0.3s;
        }
        .btn-remove-link:hover {
            color: #dc3545;
        }

        .gold-btn {
            background: var(--gold);
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 500;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: inline-block;
            text-decoration: none;
        }
        .gold-btn:hover {
            background: var(--gold-hover);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3);
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 80px 20px;
            margin: 40px 0;
        }
        .empty-state i {
            font-size: 4rem;
            color: rgba(212, 175, 55, 0.5);
            margin-bottom: 25px;
        }
        .empty-state h2 {
            font-size: 2.2rem;
            margin-bottom: 15px;
        }
        .empty-state p {
            color: var(--warm-gray);
            font-size: 1.1rem;
            margin-bottom: 30px;
        }

        /* Pagination */
        .pagination {
            display: flex;
            justify-content: center;
            margin-top: 40px;
            margin-bottom: 60px;
            gap: 10px;
        }
        .pagination a, .pagination span {
            padding: 10px 20px;
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 8px;
            text-decoration: none;
            color: var(--dark);
            background: rgba(255,255,255,0.5);
            backdrop-filter: blur(5px);
            transition: all 0.3s;
        }
        .pagination a:hover {
            background: var(--gold);
            color: white;
            border-color: var(--gold);
        }

        /* Responsive Design */
        @media (max-width: 1200px) {
            .wishlist-grid { grid-template-columns: repeat(3, 1fr); }
        }
        
        @media (max-width: 991px) {
            .nav-links { display: none; }
            .nav-icons { display: none; }
            .mobile-menu-btn { display: block; }
        }

        @media (max-width: 768px) {
            .wishlist-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
            .product-img { height: 180px; }
            .product-name { font-size: 1.1rem; }
            .btn-outline-gold { padding: 8px 10px; font-size: 0.8rem; }
        }
        
        @media (min-width: 992px) {
        }
        /* Mobile Offcanvas Overrides */
        .offcanvas {
            background-color: #1A1A1A !important;
            color: #F5F1EB !important;
        }
        .offcanvas .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
        }
        .offcanvas a {
            color: #F5F1EB !important;
            text-decoration: none;
        }
        .offcanvas-body > a {
            font-family: 'Marcellus', serif;
            font-size: 1.5rem;
            margin-bottom: 20px;
            display: block;
        }
        .offcanvas a:hover {
            color: #d4af37 !important;
        }
    </style>
</head>
<body>

    <!-- Top Bar -->
    <div class="top-bar">Free Worldwide Shipping | Authenticity Guaranteed</div>

    <!-- Navigation -->
    <nav class="navbar-luxury">
        <div class="navbar-brand"><a href="/" style="text-decoration:none;"><h1>LUXE TIME</h1></a></div>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/shope">Shop</a>
            <a href="/shope">Collections</a>
            <a href="/blog">Blog</a>
            <a href="/contact">Contact</a>
        </div>
        <div class="nav-icons">
            <a onclick="document.getElementById('searchOverlay').classList.add('active'); document.getElementById('mainSearch').focus();"><i class="fa-solid fa-magnifying-glass"></i></a>
            <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
            <a href="/cart" style="position:relative;">
                <i class="fa-solid fa-cart-shopping"></i>
            </a>
            <% if (typeof user !== 'undefined' && user) { %>
                <a href="/profile" title="Profile">
                    <% if (user.image && user.image.length > 0) { %>
                        <img src="<%= user.image[0] %>" alt="Profile" class="profile-img-nav">
                    <% } else { %>
                        <i class="fa-regular fa-user"></i>
                    <% } %>
                </a>
                <a href="/logout" title="Logout"><i class="fa-solid fa-right-from-bracket"></i></a>
            <% } else { %>
                <a href="/login" title="Login"><i class="fa-regular fa-user"></i></a>
            <% } %>
        </div>
        <button class="mobile-menu-btn" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu"><i class="fa-solid fa-bars"></i></button>
    </nav>

    <!-- Mobile Offcanvas Menu -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu">
        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title serif">LUXE TIME</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column text-center mt-5">
            <a href="/">Home</a>
            <a href="/shope">Shop</a>
            <a href="/shope">Collections</a>
            <a href="/blog">Blog</a>
            <a href="/contact">Contact</a>
            <a href="/cart">Cart</a>
            <a href="/wishlist">Wishlist</a>
            <hr class="border-secondary my-4">
            <div class="d-flex justify-content-center gap-4 mt-3">
                <a onclick="document.getElementById('searchOverlay').classList.add('active');" style="cursor: pointer;"><i class="fa-solid fa-magnifying-glass"></i></a>
                <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
                <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
                <a href="<%= (typeof user !== 'undefined' && user) ? '/profile' : '/login' %>"><i class="fa-regular fa-user"></i></a>
                <% if (typeof user !== 'undefined' && user) { %> <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i></a> <% } %>
            </div>
        </div>
    </div>

    <!-- Search Overlay -->
    <div class="search-overlay" id="searchOverlay">
        <i class="fa-solid fa-xmark close-search" onclick="document.getElementById('searchOverlay').classList.remove('active');"></i>
        <input type="text" id="mainSearch" class="search-box-large" placeholder="Type to search...">
    </div>

    <div class="container">
        <div class="page-header">
            <h1 class="serif">Your Wishlist</h1>
            <% if (wishlist && wishlist.items && wishlist.items.length > 0) { %>
                <span class="item-count">(<%= wishlist.items.length %> Items)</span>
            <% } %>
        </div>

        <% if (!wishlist || !wishlist.items || wishlist.items.length === 0) { %>
            <div class="empty-state glass-panel">
                <i class="fas fa-heart"></i>
                <h2 class="serif">Your wishlist is empty</h2>
                <p>Curate your personal collection of timeless masterpieces.</p>
                <a href="/shope" class="gold-btn">Discover Our Collection</a>
            </div>
        <% } else { %>
            <div class="wishlist-grid">
                <% wishlist.items.forEach(item => { %>
                    <div class="wishlist-card glass-panel">
                        <i class="fas fa-heart heart-icon"></i>
                        
                        <% if (item.product.imagePaths && item.product.imagePaths.length > 0) { %>
                            <img src="<%= item.product.imagePaths[0] %>" alt="<%= item.product.name %>" class="product-img" onerror="this.src='https://via.placeholder.com/300?text=Watch'">
                        <% } else { %>
                            <img src="https://via.placeholder.com/300?text=No+Image" alt="<%= item.product.name %>" class="product-img">
                        <% } %>

                        <div class="product-brand"><%= item.product.brand || 'Luxe Brand' %></div>
                        <div class="product-name serif"><%= item.product.name %></div>
                        <div class="product-price serif">$<%= item.product.price.toFixed(2) %></div>

                        <button onclick="addToCart('<%= item.product._id %>', '<%= item.color %>')" class="btn-outline-gold">
                            Add to Cart
                        </button>
                        
                        <button onclick="removeFromWishlist('<%= item._id %>')" class="btn-remove-link">
                            Remove
                        </button>
                    </div>
                <% }); %>
            </div>

            <!-- Pagination (if applicable) -->
            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
            <div class="pagination">
                <% if (currentPage > 1) { %>
                    <a href="/wishlist?page=<%= currentPage - 1 %>">
                        <i class="fas fa-chevron-left"></i> Previous
                    </a>
                <% } %>

                <span>Page <%= currentPage %> of <%= totalPages %></span>

                <% if (currentPage < totalPages) { %>
                    <a href="/wishlist?page=<%= currentPage + 1 %>">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                <% } %>
            </div>
            <% } %>
        <% } %>
    </div>

    <script>
        async function removeFromWishlist(itemId) {
            try {
                const response = await fetch(`/wishlist/${itemId}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();

                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Removed!',
                        text: 'Item removed from your wishlist.',
                        showConfirmButton: false,
                        timer: 1500,
                        background: 'rgba(255, 255, 255, 0.95)',
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire({ icon: 'error', title: 'Oops...', text: data.message || 'Failed to remove item' });
                }
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong!' });
            }
        }

        async function addToCart(productId, color) {
            try {
                const response = await fetch('/cart', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, color, quantity: 1 })
                });

                const data = await response.json();

                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Added to Cart',
                        text: 'The item has been added to your cart.',
                        showConfirmButton: false,
                        timer: 1500,
                        background: 'rgba(255, 255, 255, 0.95)',
                    });
                } else {
                    Swal.fire({ icon: 'error', title: 'Oops...', text: data.message || 'Failed to add to cart' });
                }
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong!' });
            }
        }

        // Mobile offcanvas is handled by Bootstrap JS
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>