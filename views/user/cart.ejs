<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopping Cart | LUXE TIME</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --gold: #d4af37;
            --gold-hover: #b5952f;
            --warm-gray: #8c8c8c;
            --dark: #1a1a1a;
            --light-bg: #fdfbf7;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);
            min-height: 100vh;
            color: var(--dark);
        }

        .serif {
            font-family: 'Marcellus', serif;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.7);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
            border-radius: 16px;
        }

        /* Navbar */
        .top-bar {
            background-color: var(--dark); color: var(--light-bg); text-align: center;
            padding: 8px 0; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; font-weight: 300;
        }
        .navbar-luxury {
            background-color: rgba(255, 255, 255, 0.95); padding: 20px 5%; display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid rgba(26,26,26,0.1); position: sticky; top: 0; z-index: 1000; backdrop-filter: blur(10px);
        }
        .navbar-brand h1 { margin: 0; font-size: 1.8rem; font-family: 'Marcellus', serif; color: var(--dark); }
        .nav-links { display: flex; gap: 30px; }
        .nav-links a { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 500; position: relative; transition: color 0.3s; text-decoration: none; color: var(--dark); }
        .nav-links a::after { content: ''; position: absolute; width: 0; height: 1px; bottom: -4px; left: 0; background-color: var(--gold); transition: width 0.3s; }
        .nav-links a:hover { color: var(--gold); }
        .nav-links a:hover::after { width: 100%; }
        .nav-icons { display: flex; gap: 20px; align-items: center; }
        .nav-icons a { font-size: 1.1rem; transition: color 0.3s; cursor: pointer; color: var(--dark); text-decoration: none; position: relative; }
        .nav-icons a:hover { color: var(--gold); }
        .profile-img-nav { width: 25px; height: 25px; border-radius: 50%; object-fit: cover; }
        .mobile-menu-btn { display: none; font-size: 1.5rem; cursor: pointer; background: none; border: none; color: var(--dark); }

        /* Search Input Overlay - Glassmorphism Luxury */
        .search-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(10, 10, 10, 0.4);
            backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            z-index: 1100; display: flex; justify-content: center; align-items: center;
            opacity: 0; visibility: hidden; transition: opacity 0.4s ease, visibility 0.4s ease;
        }
        .search-overlay.active { opacity: 1; visibility: visible; }
        .search-container {
            display: flex; align-items: center; width: 90%; max-width: 800px;
            background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 24px; padding: 20px 30px; box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            transform: translateY(-30px); transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .search-overlay.active .search-container { transform: translateY(0); }
        .search-icon-large { color: var(--gold); font-size: 1.5rem; margin-right: 20px; }
        .search-box-large {
            flex: 1; border: none; background: transparent; color: #ffffff;
            font-size: 1.8rem; outline: none; font-family: 'Marcellus', serif;
            font-weight: 300; letter-spacing: 1px;
        }
        .search-box-large::placeholder { color: rgba(255, 255, 255, 0.4); }
        .ai-search-icon { color: rgba(255, 255, 255, 0.5); font-size: 1.5rem; margin-left: 15px; cursor: pointer; transition: color 0.3s; }
        .ai-search-icon:hover { color: var(--gold); }
        .close-search { color: rgba(255, 255, 255, 0.5); font-size: 1.8rem; cursor: pointer; margin-left: 20px; transition: color 0.3s, transform 0.3s; }
        .close-search:hover { color: #ffffff; transform: rotate(90deg); }

        @media (max-width: 768px) {
            .search-container { width: 95%; padding: 15px 20px; border-radius: 16px; }
            .search-box-large { font-size: 1.2rem; }
            .search-icon-large, .ai-search-icon, .close-search { font-size: 1.2rem; margin-right: 10px; margin-left: 10px; }
        }

        /* Header */
        .page-header {
            display: flex;
            align-items: baseline;
            gap: 15px;
            margin: 40px 0 30px;
        }
        .page-header h1 {
            font-size: 2.5rem;
            margin: 0;
            color: var(--dark);
        }
        .item-count {
            color: var(--warm-gray);
            font-size: 1.1rem;
            font-weight: 400;
        }

        /* Cart Layout */
        .cart-layout {
            display: flex;
            gap: 30px;
            align-items: flex-start;
        }
        .cart-items-section {
            flex: 0 0 65%;
            padding: 30px;
        }
        .order-summary-section {
            flex: 0 0 calc(35% - 30px);
            padding: 30px;
            position: sticky;
            top: 100px;
        }

        /* Cart Item Row */
        .cart-item {
            display: flex;
            align-items: center;
            padding: 20px 0;
            border-bottom: 1px solid rgba(0,0,0,0.08);
            position: relative;
        }
        .cart-item:last-child {
            border-bottom: none;
        }
        .item-thumb {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 8px;
            margin-right: 20px;
            background: #fff;
        }
        .item-details {
            flex-grow: 1;
        }
        .item-brand {
            font-variant: small-caps;
            color: var(--warm-gray);
            font-size: 0.85rem;
            letter-spacing: 1px;
            margin-bottom: 2px;
        }
        .item-name {
            font-size: 1.1rem;
            font-weight: 500;
            margin-bottom: 5px;
            color: var(--dark);
        }
        .item-meta {
            font-size: 0.85rem;
            color: var(--warm-gray);
            display: flex;
            gap: 15px;
            align-items: center;
        }
        .color-dot {
            display: inline-block; width: 12px; height: 12px; border-radius: 50%; border: 1px solid #ddd; vertical-align: middle; margin-right: 5px;
        }
        
        /* Quantity Stepper */
        .quantity-stepper {
            display: flex;
            align-items: center;
            background: rgba(255,255,255,0.8);
            border-radius: 25px;
            border: 1px solid rgba(0,0,0,0.1);
            padding: 2px 5px;
            margin: 0 20px;
        }
        .qty-btn {
            background: transparent;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--dark);
            transition: background 0.2s;
            font-size: 1.2rem;
        }
        .qty-btn:hover { background: rgba(0,0,0,0.05); }
        .qty-val {
            min-width: 30px;
            text-align: center;
            font-weight: 500;
        }

        .line-price {
            font-weight: 600;
            font-size: 1.1rem;
            min-width: 90px;
            text-align: right;
            margin-right: 20px;
        }

        .remove-btn {
            background: transparent;
            border: none;
            color: var(--warm-gray);
            cursor: pointer;
            padding: 10px;
            transition: color 0.2s;
            font-size: 1.2rem;
        }
        .remove-btn:hover { color: #dc3545; }

        /* Order Summary */
        .order-summary-section h2 {
            font-size: 1.5rem;
            margin-bottom: 25px;
            color: var(--dark);
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
            color: var(--dark);
            font-size: 0.95rem;
        }
        .summary-row.discount {
            color: #28a745;
        }
        .summary-divider {
            height: 1px;
            background: rgba(0,0,0,0.1);
            margin: 20px 0;
        }
        .summary-total {
            display: flex;
            justify-content: space-between;
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 25px;
        }
        .promo-code {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
        }
        .promo-input {
            flex-grow: 1;
            background: rgba(255,255,255,0.5);
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 8px;
            padding: 10px 15px;
            outline: none;
        }
        .promo-apply {
            color: var(--dark);
            font-weight: 500;
            background: transparent;
            border: none;
            text-decoration: underline;
        }
        
        .gold-btn {
            background: var(--gold);
            color: white;
            border: none;
            width: 100%;
            padding: 15px;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 500;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-align: center;
            display: block;
            text-decoration: none;
        }
        .gold-btn:hover {
            background: var(--gold-hover);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3);
        }

        .payment-icons {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 20px;
            color: var(--warm-gray);
            font-size: 1.5rem;
        }

        /* Empty Cart */
        .empty-cart-state {
            text-align: center;
            padding: 60px 20px;
        }
        .empty-icon {
            font-size: 4rem;
            color: rgba(212, 175, 55, 0.5);
            margin-bottom: 20px;
        }
        .empty-title {
            font-size: 2rem;
            margin-bottom: 15px;
        }
        .empty-btn {
            display: inline-block;
            margin-top: 20px;
            width: auto;
            padding: 15px 40px;
        }

        /* Cross-sell section */
        .cross-sell {
            margin-top: 60px;
            margin-bottom: 60px;
        }
        .cross-sell h3 {
            text-align: center;
            font-size: 2rem;
            margin-bottom: 30px;
        }
        .cross-sell-grid {
            display: flex;
            gap: 20px;
        }
        .cs-card {
            flex: 1;
            padding: 15px;
            text-align: center;
            transition: transform 0.3s;
        }
        .cs-card:hover {
            transform: translateY(-5px);
        }
        .cs-img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 15px;
        }
        .cs-brand { font-variant: small-caps; color: var(--warm-gray); font-size: 0.8rem; }
        .cs-name { font-weight: 500; font-size: 1rem; margin-bottom: 5px; }
        .cs-price { color: var(--gold); font-weight: 600; }

        /* Responsive Design */
        @media (max-width: 991px) {
            .cart-layout {
                flex-direction: column;
            }
            .cart-items-section, .order-summary-section {
                flex: none;
                width: 100%;
            }
            .order-summary-section {
                position: static;
                margin-top: 20px;
            }
            .nav-links { display: none; }
            .nav-icons { display: none; }
            .mobile-menu-btn { display: block; }
        }

        @media (max-width: 768px) {
            .cart-item {
                flex-wrap: wrap;
                position: relative;
            }
            .item-details {
                width: calc(100% - 100px);
            }
            .quantity-stepper {
                margin: 15px 0 0 0;
            }
            .line-price {
                margin: 15px 0 0 auto;
            }
            .remove-btn {
                position: absolute;
                top: 10px;
                right: 0;
            }
            .cross-sell-grid {
                overflow-x: auto;
                scroll-snap-type: x mandatory;
                padding-bottom: 20px;
            }
            .cs-card {
                flex: 0 0 70%;
                scroll-snap-align: center;
            }
            
            /* Sticky checkout bar on mobile */
            .mobile-sticky-checkout {
                position: fixed;
                bottom: 0;
                left: 0;
                width: 100%;
                background: rgba(255,255,255,0.9);
                backdrop-filter: blur(15px);
                padding: 15px;
                box-shadow: 0 -5px 20px rgba(0,0,0,0.1);
                z-index: 100;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }
            .mobile-sticky-checkout .gold-btn {
                width: auto;
                padding: 10px 20px;
                margin: 0;
            }
            .mobile-sticky-total {
                font-family: 'Marcellus', serif;
                font-size: 1.3rem;
                font-weight: 600;
            }
            .order-summary-section .gold-btn {
                display: none; /* Hide original button on mobile to use sticky */
            }
            body { padding-bottom: 80px; } /* Space for sticky bar */
        }
        
        @media (min-width: 769px) {
            .mobile-sticky-checkout { display: none; }
        }

        .out-of-stock-badge {
            background: #dc3545; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem; margin-left: 10px;
        }

        /* Mobile Offcanvas Overrides */
        .offcanvas {
            background-color: #1A1A1A !important;
            color: #F5F1EB !important;
        }
        .offcanvas .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
        }
        .offcanvas a {
            color: #F5F1EB !important;
            text-decoration: none;
        }
        .offcanvas-body > a {
            font-family: 'Marcellus', serif;
            font-size: 1.5rem;
            margin-bottom: 20px;
            display: block;
        }
        .offcanvas a:hover {
            color: #d4af37 !important;
        }
    </style>
</head>
<body>

    <!-- Top Bar -->
    <div class="top-bar">Free Worldwide Shipping | Authenticity Guaranteed</div>

    <!-- Navigation -->
    <nav class="navbar-luxury">
        <div class="navbar-brand"><a href="/" style="text-decoration:none;"><h1>LUXE TIME</h1></a></div>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/shope">Shop</a>
            <a href="/shope">Collections</a>
            <a href="/blog">Blog</a>
            <a href="/contact">Contact</a>
        </div>
        <div class="nav-icons">
            <a onclick="document.getElementById('searchOverlay').classList.add('active'); document.getElementById('mainSearch').focus();"><i class="fa-solid fa-magnifying-glass"></i></a>
            <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
            <a href="/cart" style="position:relative;">
                <i class="fa-solid fa-cart-shopping"></i>
                <% if (cart && cart.length > 0) { %>
                    <span style="position: absolute; top: -8px; right: -12px; background: var(--gold); color: white; font-size: 0.6rem; padding: 0.1rem 0.4rem; border-radius: 50%; min-width: 16px; height: 16px; display: flex; align-items: center; justify-content: center;"><%= cart.length %></span>
                <% } %>
            </a>
            <% if (typeof user !== 'undefined' && user) { %>
                <a href="/profile" title="Profile">
                    <% if (user.image && user.image.length > 0) { %>
                        <img src="<%= user.image[0] %>" alt="Profile" class="profile-img-nav">
                    <% } else { %>
                        <i class="fa-regular fa-user"></i>
                    <% } %>
                </a>
                <a href="/logout" title="Logout"><i class="fa-solid fa-right-from-bracket"></i></a>
            <% } else { %>
                <a href="/login" title="Login"><i class="fa-regular fa-user"></i></a>
            <% } %>
        </div>
        <button class="mobile-menu-btn" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu"><i class="fa-solid fa-bars"></i></button>
    </nav>

    <!-- Mobile Offcanvas Menu -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu">
        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title serif">LUXE TIME</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column text-center mt-5">
            <a href="/">Home</a>
            <a href="/shope">Shop</a>
            <a href="/shope">Collections</a>
            <a href="/blog">Blog</a>
            <a href="/contact">Contact</a>
            <a href="/cart">Cart</a>
            <a href="/wishlist">Wishlist</a>
            <hr class="border-secondary my-4">
            <div class="d-flex justify-content-center gap-4 mt-3">
                <a onclick="const mobileMenu = document.getElementById('mobileMenu'); const bsOffcanvas = bootstrap.Offcanvas.getInstance(mobileMenu); if(bsOffcanvas) bsOffcanvas.hide(); document.getElementById('searchOverlay').classList.add('active'); setTimeout(() => document.getElementById('mainSearch').focus(), 400);" style="cursor: pointer;"><i class="fa-solid fa-magnifying-glass"></i></a>
                <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
                <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
                <a href="<%= (typeof user !== 'undefined' && user) ? '/profile' : '/login' %>"><i class="fa-regular fa-user"></i></a>
                <% if (typeof user !== 'undefined' && user) { %> <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i></a> <% } %>
            </div>
        </div>
    </div>

    <!-- Search Overlay - Glassmorphism -->
    <div class="search-overlay" id="searchOverlay">
        <div class="search-container">
            <i class="fa-solid fa-magnifying-glass search-icon-large"></i>
            <input type="text" id="mainSearch" class="search-box-large" placeholder="Search references, models, or calibers...">
            <i class="fa-solid fa-camera ai-search-icon" title="AI Image Search"></i>
            <i class="fa-solid fa-xmark close-search" onclick="document.getElementById('searchOverlay').classList.remove('active');"></i>
        </div>
    </div>

    <div class="container">
        <div class="page-header">
            <h1 class="serif">Your Cart</h1>
            <% if (cart && cart.length > 0) { %>
                <span class="item-count">(<%= cart.length %> Items)</span>
            <% } %>
        </div>

        <% if (cart && cart.length > 0) { %>
            <div class="cart-layout">
                <div class="cart-items-section glass-panel">
                    <% cart.forEach(item => { %>
                        <div class="cart-item" id="cart-item-<%= item.id %>">
                            <img src="<%= item.image || '/images/placeholder.jpg' %>" alt="<%= item.name %>" class="item-thumb" onerror="this.src='https://via.placeholder.com/80x80?text=Watch'">
                            
                            <div class="item-details">
                                <div class="item-brand"><%= item.brand || 'Luxe Brand' %></div>
                                <div class="item-name"><%= item.name %></div>
                                <div class="item-meta">
                                    <span>
                                        <span class="color-dot" style="background-color: <%= item.color || '#000' %>;"></span>
                                        <%= item.color || 'Standard' %>
                                    </span>
                                    <% if (item.stock <= 0) { %>
                                        <span class="out-of-stock-badge">Out of Stock</span>
                                    <% } %>
                                </div>
                            </div>

                            <div class="quantity-stepper">
                                <button class="qty-btn" onclick="updateQuantity('<%= item.productId %>', -1)">-</button>
                                <span class="qty-val" id="quantity-<%= item.productId %>"><%= item.quantity %></span>
                                <button class="qty-btn" onclick="updateQuantity('<%= item.productId %>', 1)">+</button>
                            </div>

                            <div class="line-price serif">
                                $<%= (item.price * item.quantity).toFixed(2) %>
                            </div>

                            <button class="remove-btn" onclick="removeFromCart('<%= item.productId %>')">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    <% }) %>
                </div>

                <div class="order-summary-section glass-panel">
                    <h2 class="serif">Order Summary</h2>
                    
                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span id="subtotal" class="serif">$<%= cart.reduce((acc, item)=> acc + (item.discountedPrice * item.quantity), 0).toFixed(2) %></span>
                    </div>
                    
                    <div class="summary-row">
                        <span>Estimated Shipping</span>
                        <span class="serif">$0.00</span>
                    </div>

                    <div class="summary-row">
                        <span>Tax (10%)</span>
                        <span id="tax" class="serif">$<%= (cart.reduce((acc, item)=> acc + (item.discountedPrice * item.quantity), 0) * 0.1).toFixed(2) %></span>
                    </div>

                    <% if (typeof totalOfferDiscount !== 'undefined' && totalOfferDiscount > 0) { %>
                    <div class="summary-row discount">
                        <span>Offer Discount</span>
                        <span id="totalOfferDiscount" class="serif">-$<%= totalOfferDiscount.toFixed(2) %></span>
                    </div>
                    <% } %>

                    <div class="summary-divider"></div>

                    <div class="promo-code">
                        <input type="text" class="promo-input" placeholder="Promo Code">
                        <button class="promo-apply">Apply</button>
                    </div>

                    <div class="summary-total serif">
                        <span>Total</span>
                        <span id="total">$<%= (cart.reduce((acc, item)=> acc + (item.discountedPrice * item.quantity), 0) * 1.1).toFixed(2) %></span>
                    </div>

                    <a href="javascript:void(0);" class="gold-btn" id="checkout-btn">
                        Proceed to Checkout
                    </a>

                    <div class="payment-icons">
                        <i class="fab fa-cc-visa"></i>
                        <i class="fab fa-cc-mastercard"></i>
                        <i class="fab fa-cc-amex"></i>
                        <i class="fab fa-cc-paypal"></i>
                    </div>
                </div>
            </div>

            <!-- Mobile Sticky Bar -->
            <div class="mobile-sticky-checkout">
                <div>
                    <div style="font-size: 0.8rem; color: var(--warm-gray);">Total</div>
                    <div class="mobile-sticky-total">$<%= (cart.reduce((acc, item)=> acc + (item.discountedPrice * item.quantity), 0) * 1.1).toFixed(2) %></div>
                </div>
                <a href="javascript:void(0);" class="gold-btn" id="mobile-checkout-btn">Checkout</a>
            </div>

        <% } else { %>
            <div class="empty-cart-state glass-panel">
                <i class="fas fa-clock empty-icon"></i>
                <h2 class="empty-title serif">Your cart is empty</h2>
                <p style="color: var(--warm-gray); font-size: 1.1rem;">Discover timeless elegance and add to your collection.</p>
                <a href="/shope" class="gold-btn empty-btn">Explore Our Collection</a>
            </div>
        <% } %>

        <div class="cross-sell">
            <h3 class="serif">Complete Your Collection</h3>
            <div class="cross-sell-grid">
