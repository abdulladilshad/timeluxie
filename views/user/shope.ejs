<!DOCTYPE html>
<html lang="en">
<head>
  <title>Shop - LUXE TIME WORLD</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">

  <style>
    :root {
      --ivory: #F5F1EB;
      --charcoal: #1A1A1A;
      --gold: #C5A66E;
      --warm-gray: #8C8C8C;
      --font-serif: 'Playfair Display', serif;
      --font-sans: 'Inter', sans-serif;
    }

    body {
      background-color: var(--ivory);
      color: var(--charcoal);
      font-family: var(--font-sans);
      margin: 0;
      padding: 0;
    }

    h1, h2, h3, h4, h5, h6, .serif { font-family: var(--font-serif); }
    a { text-decoration: none; color: inherit; }

    /* Navbar */
    .top-bar {
      background-color: var(--charcoal); color: var(--ivory); text-align: center;
      padding: 8px 0; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; font-weight: 300;
    }
    .navbar-luxury {
      background-color: var(--ivory); padding: 20px 5%; display: flex; justify-content: space-between; align-items: center;
      border-bottom: 1px solid rgba(26,26,26,0.1); position: sticky; top: 0; z-index: 1000;
    }
    .navbar-brand h1 { margin: 0; font-size: 1.8rem; font-weight: 700; letter-spacing: 2px; color: var(--charcoal); }
    .nav-links { display: flex; gap: 30px; }
    .nav-links a { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 500; position: relative; transition: color 0.3s; }
    .nav-links a::after { content: ''; position: absolute; width: 0; height: 1px; bottom: -4px; left: 0; background-color: var(--gold); transition: width 0.3s; }
    .nav-links a:hover { color: var(--gold); }
    .nav-links a:hover::after { width: 100%; }
    .nav-icons { display: flex; gap: 20px; align-items: center; }
    .nav-icons a { font-size: 1.1rem; transition: color 0.3s; cursor: pointer; }
    .nav-icons a:hover { color: var(--gold); }
    .profile-img-nav { width: 25px; height: 25px; border-radius: 50%; object-fit: cover; }
    .mobile-menu-btn { display: none; font-size: 1.5rem; cursor: pointer; background: none; border: none; color: var(--charcoal); }

    @media (max-width: 991px) {
      .nav-links { display: none; }
      .nav-icons { display: none; }
      .mobile-menu-btn { display: block; }
    }
    .offcanvas { background-color: var(--charcoal); color: var(--ivory); }
    .offcanvas .btn-close { filter: invert(1) grayscale(100%) brightness(200%); }
    .offcanvas a { color: var(--ivory); font-family: var(--font-serif); font-size: 1.5rem; margin-bottom: 20px; display: block; }
    .offcanvas a:hover { color: var(--gold); }

    /* Header */
    .shop-header {
      padding: 60px 5% 40px; text-align: center;
    }
    .shop-header h1 { font-size: 3.5rem; margin-bottom: 10px; }
    .breadcrumbs { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; color: var(--warm-gray); }
    .breadcrumbs a { color: var(--charcoal); transition: color 0.3s; }
    .breadcrumbs a:hover { color: var(--gold); }

    /* Filter Bar */
    .filter-bar {
      padding: 20px 5%; border-top: 1px solid rgba(26,26,26,0.1); border-bottom: 1px solid rgba(26,26,26,0.1);
      display: flex; justify-content: space-between; align-items: center; position: sticky; top: 73px; background-color: var(--ivory); z-index: 990;
    }
    .filters-left, .filters-right { display: flex; gap: 20px; align-items: center; }
    .filter-select {
      background: transparent; border: none; font-family: var(--font-sans); font-size: 0.85rem; text-transform: uppercase;
      letter-spacing: 1px; color: var(--charcoal); cursor: pointer; outline: none; border-bottom: 1px solid transparent; padding-bottom: 5px;
    }
    .filter-select:hover, .filter-select:focus { border-color: var(--gold); }
    .filter-btn-mobile { display: none; background: transparent; border: 1px solid var(--charcoal); padding: 8px 20px; text-transform: uppercase; letter-spacing: 1px; font-size: 0.85rem; }

    /* Active Filters */
    .active-filters { padding: 20px 5% 0; display: flex; gap: 10px; flex-wrap: wrap; }
    .filter-pill {
      border: 1px solid var(--warm-gray); padding: 5px 15px; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;
      display: flex; align-items: center; gap: 8px; border-radius: 20px; color: var(--charcoal); cursor: pointer; transition: 0.3s;
    }
    .filter-pill:hover { border-color: var(--charcoal); background-color: var(--charcoal); color: var(--ivory); }

    /* Product Grid */
    .shop-container { padding: 40px 5% 100px; }
    .product-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px 20px;
    }
    
    .product-card { position: relative; }
    .product-img-wrapper {
      background-color: #fff; padding: 30px; margin-bottom: 15px; position: relative; transition: 0.3s;
    }
    .product-img-wrapper img { width: 100%; aspect-ratio: 1; object-fit: contain; }
    .wishlist-btn {
      position: absolute; top: 15px; right: 15px; background: transparent; border: none; font-size: 1.2rem;
      color: var(--warm-gray); opacity: 0; transition: 0.3s; cursor: pointer;
    }
    .product-card:hover .wishlist-btn { opacity: 1; color: var(--charcoal); }
    .wishlist-btn:hover { color: #e74c3c !important; }
    
    .product-brand { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; color: var(--warm-gray); margin-bottom: 5px; }
    .product-name { font-size: 1.2rem; margin-bottom: 5px; color: var(--charcoal); }
    .product-price { font-size: 1rem; font-weight: 500; color: var(--gold); }
    .product-price del { color: var(--warm-gray); font-size: 0.85rem; margin-right: 8px; }

    /* Pagination */
    .pagination-wrapper { margin-top: 60px; text-align: center; }
    .pagination { display: inline-flex; gap: 5px; list-style: none; padding: 0; }
    .page-link {
      color: var(--charcoal); background: transparent; border: 1px solid transparent; width: 40px; height: 40px;
      display: flex; justify-content: center; align-items: center; text-decoration: none; font-family: var(--font-serif); font-size: 1.1rem; transition: 0.3s;
    }
    .page-link:hover, .page-item.active .page-link { border-color: var(--gold); color: var(--gold); }
    .page-item.disabled .page-link { color: var(--warm-gray); pointer-events: none; }

    /* Footer */
    .footer-luxury { background-color: var(--charcoal); color: var(--ivory); padding: 80px 5% 40px 5%; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 2fr; gap: 60px; margin-bottom: 60px; }
    .footer-col h4 { font-family: var(--font-sans); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 30px; color: var(--gold); }
    .footer-col p, .footer-col a { color: #999; font-size: 0.9rem; line-height: 1.8; transition: color 0.3s; }
    .footer-col a { display: block; margin-bottom: 15px; }
    .footer-col a:hover { color: var(--ivory); }
    .newsletter-form { display: flex; margin-top: 20px; border-bottom: 1px solid rgba(255,255,255,0.2); }
    .newsletter-form input { background: transparent; border: none; color: var(--ivory); padding: 10px 0; width: 100%; }
    .newsletter-form input:focus { outline: none; }
    .newsletter-form button { background: transparent; border: none; color: var(--gold); text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem; cursor: pointer; padding: 0 10px; }
    .social-links { display: flex; gap: 20px; margin-top: 30px; }
    .social-links a { color: var(--ivory); font-size: 1.2rem; }
    .footer-bottom { text-align: center; border-top: 1px solid rgba(197, 166, 110, 0.3); padding-top: 30px; font-size: 0.8rem; color: #666; }

    /* Mobile Filter Drawer */
    .filter-drawer {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--ivory);
      z-index: 1050; transform: translateY(100%); transition: transform 0.4s ease-in-out;
      overflow-y: auto; padding: 20px; display: flex; flex-direction: column;
    }
    .filter-drawer.open { transform: translateY(0); }
    .drawer-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--charcoal); padding-bottom: 15px; margin-bottom: 20px; }
    .drawer-header h3 { margin: 0; font-size: 1.5rem; text-transform: uppercase; letter-spacing: 2px; }
    .drawer-close { background: transparent; border: none; font-size: 1.5rem; cursor: pointer; }
    .drawer-section { margin-bottom: 30px; }
    .drawer-section h4 { font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; color: var(--warm-gray); }

    /* Search Input Overlay */
    .search-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(26,26,26,0.95);
      z-index: 1100; display: none; justify-content: center; align-items: center; flex-direction: column;
    }
    .search-overlay.active { display: flex; }
    .search-box-large { width: 80%; max-width: 600px; border: none; border-bottom: 2px solid var(--gold); background: transparent; color: var(--ivory); font-size: 2rem; padding: 10px 0; outline: none; text-align: center; font-family: var(--font-serif); }
    .search-box-large::placeholder { color: rgba(245,241,235,0.5); }
    .close-search { position: absolute; top: 30px; right: 40px; color: var(--ivory); font-size: 2rem; cursor: pointer; }

    /* Responsive Grid */
    @media (max-width: 991px) {
      .product-grid { grid-template-columns: repeat(3, 1fr); }
      .filters-left { display: none; }
      .filter-btn-mobile { display: block; }
      .wishlist-btn { opacity: 1; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      .product-grid { grid-template-columns: repeat(2, 1fr); gap: 20px 10px; }
      .shop-header h1 { font-size: 2.5rem; }
      .product-img-wrapper { padding: 15px; }
      .product-name { font-size: 1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .footer-grid { grid-template-columns: 1fr; gap: 40px; }
      .footer-luxury { padding: 60px 5% 30px 5%; }
    }
  </style>
</head>
<body>

  <!-- Top Bar -->
  <div class="top-bar">Free Worldwide Shipping | Authenticity Guaranteed</div>

  <!-- Navigation -->
  <nav class="navbar-luxury">
    <div class="navbar-brand"><a href="/"><h1>LUXE TIME</h1></a></div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/shope">Shop</a>
      <a href="/shope">Collections</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
    </div>
    <div class="nav-icons">
      <a onclick="document.getElementById('searchOverlay').classList.add('active'); document.getElementById('mainSearch').focus();"><i class="fa-solid fa-magnifying-glass"></i></a>
      <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
      <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/profile" title="Profile">
          <% if (user.image && user.image.length > 0) { %>
            <img src="<%= user.image[0] %>" alt="Profile" class="profile-img-nav">
          <% } else { %>
            <i class="fa-regular fa-user"></i>
          <% } %>
        </a>
        <a href="/logout" title="Logout"><i class="fa-solid fa-right-from-bracket"></i></a>
      <% } else { %>
        <a href="/login" title="Login"><i class="fa-regular fa-user"></i></a>
      <% } %>
    </div>
    <button class="mobile-menu-btn" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu"><i class="fa-solid fa-bars"></i></button>
  </nav>

  <!-- Mobile Offcanvas Menu -->
  <div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu">
    <div class="offcanvas-header border-bottom border-secondary">
      <h5 class="offcanvas-title serif">LUXE TIME</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column text-center mt-5">
      <a href="/">Home</a><a href="/shope">Shop</a><a href="/shope">Collections</a><a href="/blog">Blog</a><a href="/contact">Contact</a>
      <hr class="border-secondary my-4">
      <div class="d-flex justify-content-center gap-4 mt-3">
        <a onclick="document.getElementById('searchOverlay').classList.add('active');"><i class="fa-solid fa-magnifying-glass"></i></a>
        <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
        <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
        <a href="<%= (typeof user !== 'undefined' && user) ? '/profile' : '/login' %>"><i class="fa-regular fa-user"></i></a>
        <% if (typeof user !== 'undefined' && user) { %> <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i></a> <% } %>
      </div>
    </div>
  </div>

  <!-- Search Overlay -->
  <div class="search-overlay" id="searchOverlay">
    <i class="fa-solid fa-xmark close-search" onclick="document.getElementById('searchOverlay').classList.remove('active');"></i>
    <input type="text" id="mainSearch" class="search-box-large" placeholder="Type to search...">
  </div>

  <!-- Header -->
  <header class="shop-header">
    <h1 class="serif">Our Collection</h1>
    <div class="breadcrumbs">
      <a href="/">Home</a> &nbsp;/&nbsp; Shop
    </div>
  </header>

  <!-- Filter & Sort Bar -->
  <div class="filter-bar">
    <button class="filter-btn-mobile" onclick="document.getElementById('filterDrawer').classList.add('open')">
      <i class="fa-solid fa-sliders"></i> Filter
    </button>
    <div class="filters-left">
      <select class="filter-select" id="deskCategory">
        <option value="">All Categories</option>
        <% categories.forEach(category => { %>
          <option value="<%= category._id %>" <%= selectedCategory === category._id.toString() ? 'selected' : '' %>><%= category.name %></option>
        <% }) %>
      </select>
      <select class="filter-select" id="deskPrice">
        <option value="">Price Range</option>
        <option value="5000">Under $5,000</option>
        <option value="15000">Under $15,000</option>
        <option value="50000">Under $50,000</option>
        <option value="100000">Under $100,000</option>
      </select>
    </div>
    <div class="filters-right">
      <select class="filter-select" id="sortSelect">
        <option value="">Sort: Newest</option>
        <option value="price_asc">Price: Low to High</option>
        <option value="price_desc">Price: High to Low</option>
      </select>
    </div>
  </div>

  <!-- Active Filters Pills -->
  <div class="active-filters" id="activeFiltersContainer">
    <!-- Populated by JS -->
  </div>

  <!-- Product Grid -->
  <div class="shop-container">
    <div class="product-grid" id="productGrid">
      <% products.forEach(product => { 
          const brand = product.productName.split(' ')[0];
          const image = product.imagePaths && product.imagePaths.length > 0 ? '/' + product.imagePaths[0].replace(/\\/g, '/') : '';
      %>
      <div class="product-card">
        <div class="product-img-wrapper">
          <a href="/product/<%= product._id %>"><img src="<%= image %>" alt="<%= product.productName %>"></a>
          <button class="wishlist-btn" onclick="addToWishlist('<%= product._id %>')"><i class="fa-solid fa-heart"></i></button>
        </div>
        <div class="product-brand"><%= brand %></div>
        <a href="/product/<%= product._id %>"><div class="product-name serif"><%= product.productName %></div></a>
        <div class="product-price">
          <% if (product.offerPrice) { %>
            <del>$<%= product.price.toLocaleString() %></del> $<%= product.offerPrice.toLocaleString() %>
          <% } else { %>
            $<%= product.price.toLocaleString() %>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
    
    <div class="pagination-wrapper" id="paginationContainer">
      <!-- Pagination Populated by JS -->
      <% if (totalPages > 1) { %>
        <ul class="pagination">
          <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= currentPage - 1 %>">‹</a>
          </li>
          <% for(let i=Math.max(1, currentPage - 1); i <=Math.min(totalPages, currentPage + 1); i++) { %>
            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>"><%= i %></a>
            </li>
          <% } %>
          <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= currentPage + 1 %>">›</a>
          </li>
        </ul>
      <% } %>
    </div>
  </div>

  <!-- Mobile Filter Drawer -->
  <div class="filter-drawer" id="filterDrawer">
    <div class="drawer-header">
      <h3 class="serif">Filters</h3>
      <button class="drawer-close" onclick="document.getElementById('filterDrawer').classList.remove('open')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="drawer-section">
      <h4>Category</h4>
      <select class="form-select" id="mobileCategory" style="border-radius: 0; font-family: var(--font-sans);">
        <option value="">All Categories</option>
        <% categories.forEach(category => { %>
          <option value="<%= category._id %>" <%= selectedCategory === category._id.toString() ? 'selected' : '' %>><%= category.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="drawer-section">
      <h4>Max Price</h4>
      <input type="range" class="form-range" id="mobilePriceRange" min="0" max="100000" step="1000" value="100000">
      <div class="d-flex justify-content-between mt-2" style="font-size: 0.85rem; color: var(--warm-gray);">
        <span>$0</span><span id="mobileMaxPriceDisplay">$100,000</span>
      </div>
    </div>
    <button class="btn btn-dark w-100 py-3" style="border-radius: 0; text-transform: uppercase; letter-spacing: 2px;" onclick="document.getElementById('filterDrawer').classList.remove('open'); applyFilters();">Apply Filters</button>
    <button class="btn btn-outline-dark w-100 py-3 mt-3" style="border-radius: 0; text-transform: uppercase; letter-spacing: 2px;" id="resetFiltersMobile">Clear All</button>
  </div>

  <!-- Footer -->
  <footer class="footer-luxury">
    <div class="footer-grid">
      <div class="footer-col">
        <h2 class="serif" style="color: var(--ivory); margin-bottom: 20px;">LUXE TIME</h2>
        <p>Curators of fine timepieces. We believe that a watch is more than an accessory; it is a legacy passed down through generations. Authenticity and excellence guaranteed.</p>
        <div class="social-links">
          <a href="#"><i class="fa-brands fa-instagram"></i></a>
          <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
          <a href="#"><i class="fa-brands fa-twitter"></i></a>
          <a href="#"><i class="fa-brands fa-pinterest-p"></i></a>
        </div>
      </div>
      <div class="footer-col">
        <h4>Customer Care</h4>
        <a href="/contact">Contact Us</a><a href="#">Shipping & Returns</a><a href="#">Warranty</a><a href="#">FAQ</a><a href="#">Watch Care Guide</a>
      </div>
      <div class="footer-col">
        <h4>Quick Links</h4>
        <a href="/shope">Shop All</a><a href="/shope">New Arrivals</a><a href="#">Pre-Owned</a><a href="/blog">The Journal</a><a href="#">Our Story</a>
      </div>
      <div class="footer-col">
        <h4>Newsletter</h4>
        <p>Subscribe to receive updates, access to exclusive deals, and more.</p>
        <form class="newsletter-form">
          <input type="email" placeholder="ENTER YOUR EMAIL" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> Luxe Time World. All Rights Reserved. Designed with elegance.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // JS Logic for Wishlist
    async function addToWishlist(productId) {
      try {
        const response = await fetch('/wishlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, color: 'default' })
        });
        const data = await response.json();
        if (data.success) {
          alert('Item added to wishlist!');
        } else {
          alert(data.message || 'Failed to add to wishlist');
        }
      } catch (error) {
        console.error('Error:', error);
      }
    }

    // Filtering JS Logic adapted for luxury layout
    document.addEventListener('DOMContentLoaded', function() {
      const productGrid = document.getElementById('productGrid');
      const paginationContainer = document.getElementById('paginationContainer');
      const activeFiltersContainer = document.getElementById('activeFiltersContainer');
      
      const deskCategory = document.getElementById('deskCategory');
      const deskPrice = document.getElementById('deskPrice');
      const sortSelect = document.getElementById('sortSelect');
      
      const mobileCategory = document.getElementById('mobileCategory');
      const mobilePriceRange = document.getElementById('mobilePriceRange');
      const mobileMaxPriceDisplay = document.getElementById('mobileMaxPriceDisplay');
      const resetFiltersMobile = document.getElementById('resetFiltersMobile');
      
      const mainSearch = document.getElementById('mainSearch');

      let currentFilters = {
          category: new URLSearchParams(window.location.search).get('category') || '',
          maxPrice: '',
          sort: '',
          page: new URLSearchParams(window.location.search).get('page') || 1,
          search: ''
      };

      // Events for Desktop
      if(deskCategory) deskCategory.addEventListener('change', function() { currentFilters.category = this.value; currentFilters.page = 1; syncMobile(); applyFilters(); });
      if(deskPrice) deskPrice.addEventListener('change', function() { currentFilters.maxPrice = this.value; currentFilters.page = 1; syncMobile(); applyFilters(); });
      if(sortSelect) sortSelect.addEventListener('change', function() { currentFilters.sort = this.value; currentFilters.page = 1; applyFilters(); });

      // Events for Mobile
      if(mobileCategory) mobileCategory.addEventListener('change', function() { currentFilters.category = this.value; syncDesktop(); });
      if(mobilePriceRange) {
        mobilePriceRange.addEventListener('input', function() { mobileMaxPriceDisplay.textContent = '$' + Number(this.value).toLocaleString(); });
        mobilePriceRange.addEventListener('change', function() { currentFilters.maxPrice = this.value; currentFilters.page = 1; syncDesktop(); });
      }
      if(resetFiltersMobile) resetFiltersMobile.addEventListener('click', function() {
          currentFilters = { category: '', maxPrice: '', sort: '', page: 1, search: '' };
          syncDesktop(); syncMobile(); applyFilters();
          document.getElementById('filterDrawer').classList.remove('open');
      });

      // Search Event
      let searchTimeout;
      if(mainSearch) mainSearch.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
          currentFilters.search = this.value.trim();
          currentFilters.page = 1;
          applyFilters();
        }, 500);
      });

      function syncMobile() {
        if(mobileCategory) mobileCategory.value = currentFilters.category;
        if(mobilePriceRange && currentFilters.maxPrice) { mobilePriceRange.value = currentFilters.maxPrice; mobileMaxPriceDisplay.textContent = '$' + Number(currentFilters.maxPrice).toLocaleString(); }
      }
      function syncDesktop() {
        if(deskCategory) deskCategory.value = currentFilters.category;
        if(deskPrice) deskPrice.value = currentFilters.maxPrice || "";
      }

      function updateActivePills() {
        let html = '';
        if(currentFilters.category) {
            const catName = deskCategory ? deskCategory.options[deskCategory.selectedIndex].text : 'Category';
            html += `<div class="filter-pill" onclick="removeFilter('category')">${catName} <i class="fa-solid fa-xmark"></i></div>`;
        }
        if(currentFilters.maxPrice) {
            html += `<div class="filter-pill" onclick="removeFilter('maxPrice')">Under $${Number(currentFilters.maxPrice).toLocaleString()} <i class="fa-solid fa-xmark"></i></div>`;
        }
        if(currentFilters.search) {
            html += `<div class="filter-pill" onclick="removeFilter('search')">"${currentFilters.search}" <i class="fa-solid fa-xmark"></i></div>`;
        }
        activeFiltersContainer.innerHTML = html;
      }

      window.removeFilter = function(type) {
        currentFilters[type] = '';
        currentFilters.page = 1;
        syncDesktop(); syncMobile();
        if(type === 'search' && mainSearch) mainSearch.value = '';
        applyFilters();
      };

      async function applyFilters() {
          updateActivePills();
          try {
              productGrid.innerHTML = '<div style="grid-column: 1 / -1; text-align: center; padding: 50px;">Loading...</div>';
              
              const params = new URLSearchParams();
              Object.entries(currentFilters).forEach(([key, value]) => { if (value) params.append(key, value); });
              window.history.pushState({ filters: currentFilters }, '', `${window.location.pathname}?${params.toString()}`);

              let endpoint = currentFilters.search ? '/shope/search' : '/shope/filter';
              const searchParams = new URLSearchParams();
              if (currentFilters.search) searchParams.set('term', currentFilters.search);
              if (currentFilters.category) searchParams.set('category', currentFilters.category);
              if (currentFilters.sort) searchParams.set('sort', currentFilters.sort);
              if (currentFilters.page) searchParams.set('page', currentFilters.page);
              if (currentFilters.maxPrice) searchParams.set('maxPrice', currentFilters.maxPrice);
              
              const response = await fetch(`${endpoint}?${searchParams.toString()}`);
              const data = await response.json();
              
              if (data.success) {
                  updateProductGridHTML(data.products);
                  updatePaginationHTML(data.pagination);
              } else {
                  productGrid.innerHTML = '<div style="grid-column: 1 / -1; text-align: center; padding: 50px; color: var(--warm-gray);">No products found matching your filters.</div>';
                  paginationContainer.style.display = 'none';
              }
          } catch (error) {
              console.error('Error applying filters:', error);
          }
      }

      function updateProductGridHTML(products) {
          if (!products || products.length === 0) {
              productGrid.innerHTML = '<div style="grid-column: 1 / -1; text-align: center; padding: 50px; color: var(--warm-gray);">No products found matching your filters.</div>';
              return;
          }

          productGrid.innerHTML = products.map(product => {
              const brand = product.productName.split(' ')[0];
              const image = product.imagePaths && product.imagePaths.length > 0 ? '/' + product.imagePaths[0].replace(/\\/g, '/') : '';
              const priceHtml = product.offerPrice 
                  ? `<del>$${product.price.toLocaleString()}</del> $${product.offerPrice.toLocaleString()}`
                  : `$${product.price.toLocaleString()}`;

              return `
              <div class="product-card">
                  <div class="product-img-wrapper">
                  <a href="/product/${product._id}"><img src="${image}" alt="${product.productName}"></a>
                  <button class="wishlist-btn" onclick="addToWishlist('${product._id}')"><i class="fa-solid fa-heart"></i></button>
                  </div>
                  <div class="product-brand">${brand}</div>
                  <a href="/product/${product._id}"><div class="product-name serif">${product.productName}</div></a>
                  <div class="product-price">${priceHtml}</div>
              </div>`;
          }).join('');
      }

      function updatePaginationHTML(pagination) {
          if (!pagination || pagination.totalPages <= 1) {
              paginationContainer.style.display = 'none';
              return;
          }

          const { currentPage, totalPages } = pagination;
          let html = '<ul class="pagination">';
          
          html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${currentPage - 1}">‹</a></li>`;
          
          for (let i = Math.max(1, currentPage - 1); i <= Math.min(totalPages, currentPage + 1); i++) {
              html += `<li class="page-item ${currentPage === i ? 'active' : ''}"><a class="page-link" href="#" data-page="${i}">${i}</a></li>`;
          }
          
          html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${currentPage + 1}">›</a></li>`;
          html += '</ul>';

          paginationContainer.innerHTML = html;
          paginationContainer.style.display = 'block';

          paginationContainer.querySelectorAll('.page-link').forEach(link => {
              link.addEventListener('click', function(e) {
                  e.preventDefault();
                  const pageNum = parseInt(this.dataset.page);
                  if (!isNaN(pageNum)) {
                      currentFilters.page = pageNum;
                      applyFilters();
                  }
              });
          });
      }

      window.addEventListener('popstate', function(e) {
          if (e.state && e.state.filters) {
              currentFilters = e.state.filters;
              syncDesktop(); syncMobile(); updateActivePills();
              applyFilters();
          }
      });
      
      updateActivePills(); // Initial render of pills if accessed via URL query
    });
  </script>
</body>
</html>