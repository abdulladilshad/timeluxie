<!DOCTYPE html>
<html lang="en">

<head>
  <title>Contact Us | LUXE TIME</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
    rel="stylesheet">

  <style>
    :root {
      --ivory: #F5F1EB;
      --charcoal: #1A1A1A;
      --gold: #C5A66E;
      --warm-gray: #8C8C8C;
      --light-gray: #E0DCD6;
      --font-serif: 'Playfair Display', serif;
      --font-sans: 'Inter', sans-serif;
    }

    body {
      background-color: var(--ivory);
      color: var(--charcoal);
      font-family: var(--font-sans);
      margin: 0;
      padding: 0;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6,
    .serif {
      font-family: var(--font-serif);
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    /* 1. Top Bar & Navigation (Consistent with index.ejs and blog.ejs) */
    .top-bar {
      background-color: var(--charcoal);
      color: var(--ivory);
      text-align: center;
      padding: 8px 0;
      font-size: 0.8rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      font-weight: 300;
    }

    .navbar-luxury {
      background-color: var(--ivory);
      padding: 20px 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(26, 26, 26, 0.1);
      position: sticky;
      top: 0;
      z-index: 1000;
      backdrop-filter: blur(10px);
      background-color: rgba(245, 241, 235, 0.9);
    }

    .navbar-brand h1 {
      margin: 0;
      font-size: clamp(1.4rem, 2vw, 1.8rem);
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--charcoal);
    }

    .nav-links {
      display: flex;
      gap: 30px;
    }

    .nav-links a {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 500;
      position: relative;
      transition: color 0.3s;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      width: 0;
      height: 1px;
      bottom: -4px;
      left: 0;
      background-color: var(--gold);
      transition: width 0.3s;
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: var(--gold);
    }

    .nav-links a:hover::after,
    .nav-links a.active::after {
      width: 100%;
    }

    .nav-icons {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .nav-icons a {
      font-size: 1.1rem;
      transition: color 0.3s;
    }

    .nav-icons a:hover {
      color: var(--gold);
    }

    .profile-img-nav {
      width: 25px;
      height: 25px;
      border-radius: 50%;
      object-fit: cover;
    }

    .mobile-menu-btn {
      display: none;
      font-size: 1.5rem;
      cursor: pointer;
      background: none;
      border: none;
      color: var(--charcoal);
    }

    @media (max-width: 991px) {
      .nav-links {
        display: none;
      }

      .nav-icons {
        display: none;
      }

      .mobile-menu-btn {
        display: block;
      }
    }

    /* Mobile Offcanvas Overrides */
    .offcanvas {
      background-color: var(--charcoal);
      color: var(--ivory);
    }

    .offcanvas .btn-close {
      filter: invert(1) grayscale(100%) brightness(200%);
    }

    .offcanvas a {
      color: var(--ivory);
      font-family: var(--font-serif);
      font-size: 1.5rem;
      margin-bottom: 20px;
      display: block;
    }

    .offcanvas a:hover {
      color: var(--gold);
    }

    /* 2. Page Header */
    .contact-header {
      padding: 80px 5% 40px;
      text-align: center;
    }

    .contact-header h1 {
      font-size: clamp(3rem, 5vw, 4.5rem);
      margin-bottom: 15px;
      color: var(--charcoal);
      font-weight: 400;
    }

    .contact-header p {
      font-size: clamp(1rem, 1.5vw, 1.2rem);
      color: var(--warm-gray);
      font-weight: 300;
      letter-spacing: 0.5px;
    }

    /* 3. Two-Column Section */
    .contact-layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 5% 80px;
      display: grid;
      grid-template-columns: 45% 55%;
      gap: 60px;
    }

    .contact-info {
      padding-right: 20px;
    }

    .info-block {
      margin-bottom: 40px;
    }

    .info-block h3 {
      font-size: 1.2rem;
      color: var(--charcoal);
      margin-bottom: 15px;
      font-weight: 600;
    }

    .info-block p,
    .info-block a {
      color: var(--warm-gray);
      font-size: 1rem;
      line-height: 1.8;
      display: flex;
      align-items: flex-start;
      gap: 15px;
      margin-bottom: 15px;
      transition: color 0.3s;
    }

    .info-block i {
      color: var(--gold);
      margin-top: 5px;
      font-size: 1.1rem;
    }

    .info-block a:hover {
      color: var(--charcoal);
    }

    .social-row {
      display: flex;
      gap: 20px;
      margin-top: 10px;
    }

    .social-row a {
      color: var(--charcoal);
      font-size: 1.2rem;
      width: 45px;
      height: 45px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--light-gray);
      border-radius: 50%;
      transition: all 0.3s ease;
    }

    .social-row a:hover {
      background-color: var(--gold);
      color: var(--ivory);
      border-color: var(--gold);
    }

    /* Contact Form */
    .contact-form-wrapper {
      background: #FFFFFF;
      padding: 50px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
    }

    .contact-form .form-group {
      margin-bottom: 25px;
    }

    .contact-form label {
      display: block;
      font-family: var(--font-serif);
      color: var(--charcoal);
      font-size: 1.1rem;
      margin-bottom: 10px;
    }

    .contact-form input,
    .contact-form select,
    .contact-form textarea {
      width: 100%;
      background: transparent;
      border: 1px solid var(--light-gray);
      padding: 15px 20px;
      font-family: var(--font-sans);
      font-size: 1rem;
      color: var(--charcoal);
      transition: border-color 0.3s ease;
      min-height: 48px;
    }

    .contact-form input:focus,
    .contact-form select:focus,
    .contact-form textarea:focus {
      outline: none;
      border-color: var(--gold);
    }

    .contact-form textarea {
      resize: vertical;
      min-height: 120px;
    }

    .btn-submit {
      background-color: var(--gold);
      color: var(--ivory);
      border: none;
      padding: 16px 40px;
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      cursor: pointer;
      transition: background-color 0.3s ease, transform 0.3s ease;
      font-family: var(--font-sans);
      font-weight: 500;
      min-height: 48px;
    }

    .btn-submit:hover {
      background-color: #A38656;
      transform: translateY(-2px);
    }

    @media (max-width: 991px) {
      .contact-layout {
        grid-template-columns: 1fr 1fr;
        gap: 40px;
      }

      .contact-form-wrapper {
        padding: 40px 30px;
      }
    }

    @media (max-width: 768px) {
      .contact-layout {
        grid-template-columns: 1fr;
        gap: 60px;
      }

      .contact-info {
        padding-right: 0;
      }

      .contact-form-wrapper {
        padding: 30px 20px;
        background: transparent;
        box-shadow: none;
      }

      .btn-submit {
        width: 100%;
      }
    }

    /* 4. Map Section */
    .map-section {
      width: 100%;
      height: 400px;
      margin-bottom: 80px;
      filter: grayscale(100%) contrast(1.1);
      /* Grayscale map */
    }

    .map-section iframe {
      width: 100%;
      height: 100%;
      border: 0;
    }

    @media (max-width: 768px) {
      .map-section {
        height: 200px;
      }
    }

    /* 5. FAQ Teaser */
    .faq-teaser {
      max-width: 800px;
      margin: 0 auto 100px;
      padding: 0 5%;
      text-align: center;
    }

    .faq-teaser h2 {
      font-size: clamp(2rem, 3vw, 2.5rem);
      margin-bottom: 40px;
      color: var(--charcoal);
    }

    .faq-list {
      list-style: none;
      padding: 0;
      margin: 0;
      text-align: left;
    }

    .faq-list li {
      border-bottom: 1px solid var(--light-gray);
    }

    .faq-list a {
      display: block;
      padding: 25px 0;
      font-size: 1.1rem;
      color: var(--charcoal);
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: color 0.3s;
      min-height: 48px;
      /* Generous tap target */
    }

    .faq-list a i {
      color: var(--gold);
      transition: transform 0.3s;
    }

    .faq-list a:hover {
      color: var(--gold);
    }

    .faq-list a:hover i {
      transform: translateX(5px);
    }

    /* 8. Footer (Consistent with index.ejs and blog.ejs) */
    .footer-luxury {
      background-color: var(--charcoal);
      color: var(--ivory);
      padding: 80px 5% 40px 5%;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 2fr;
      gap: 60px;
      margin-bottom: 60px;
    }

    .footer-col h4 {
      font-family: var(--font-sans);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 30px;
      color: var(--gold);
    }

    .footer-col p,
    .footer-col a {
      color: #999;
      font-size: 0.9rem;
      line-height: 1.8;
      transition: color 0.3s;
    }

    .footer-col a {
      display: block;
      margin-bottom: 15px;
    }

    .footer-col a:hover {
      color: var(--ivory);
    }

    .newsletter-form {
      display: flex;
      margin-top: 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    }

    .newsletter-form input {
      background: transparent;
      border: none;
      color: var(--ivory);
      padding: 10px 0;
      width: 100%;
    }

    .newsletter-form input:focus {
      outline: none;
    }

    .newsletter-form button {
      background: transparent;
      border: none;
      color: var(--gold);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-size: 0.8rem;
      cursor: pointer;
      padding: 0 10px;
    }

    .social-links {
      display: flex;
      gap: 20px;
      margin-top: 30px;
    }

    .social-links a {
      color: var(--ivory);
      font-size: 1.2rem;
    }

    .footer-bottom {
      text-align: center;
      border-top: 1px solid rgba(197, 166, 110, 0.3);
      padding-top: 30px;
      font-size: 0.8rem;
      color: #666;
    }

    @media (max-width: 991px) {
      .footer-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 768px) {
      .footer-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .footer-luxury {
        padding: 60px 5% 30px 5%;
      }
    }
  </style>
</head>

<body>
  <!-- 1. Top Bar -->
  <div class="top-bar">
    Free Worldwide Shipping | Authenticity Guaranteed
  </div>

  <!-- 2. Navigation -->
  <nav class="navbar-luxury">
    <div class="navbar-brand">
      <a href="/">
        <h1>LUXE TIME</h1>
      </a>
    </div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/shope">Shop</a>
      <a href="/shope">Collections</a>
      <a href="/blog">Blog</a>
      <a href="/contact" class="active">Contact</a>
    </div>
    <div class="nav-icons">
      <a href="/shope"><i class="fa-solid fa-magnifying-glass"></i></a>
      <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
      <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>

      <% if (typeof user !=='undefined' && user) { %>
        <a href="/profile" title="Profile">
          <% if (user.image && user.image.length> 0) { %>
            <img src="<%= user.image[0] %>" alt="Profile" class="profile-img-nav">
            <% } else { %>
              <i class="fa-regular fa-user"></i>
              <% } %>
        </a>
        <a href="/logout" title="Logout"><i class="fa-solid fa-right-from-bracket"></i></a>
        <% } else { %>
          <a href="/login" title="Login"><i class="fa-regular fa-user"></i></a>
          <% } %>
    </div>

    <button class="mobile-menu-btn" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
      <i class="fa-solid fa-bars"></i>
    </button>
  </nav>

  <!-- Mobile Menu Offcanvas -->
  <div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu">
    <div class="offcanvas-header border-bottom border-secondary">
      <h5 class="offcanvas-title serif">LUXE TIME</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column text-center mt-5">
      <a href="/">Home</a>
      <a href="/shope">Shop</a>
      <a href="/shope">Collections</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
      <hr class="border-secondary my-4">
      <div class="d-flex justify-content-center gap-4 mt-3">
        <a href="/shope"><i class="fa-solid fa-magnifying-glass"></i></a>
        <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
        <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
        <a href="<%= (typeof user !== 'undefined' && user) ? '/profile' : '/login' %>"><i
            class="fa-regular fa-user"></i></a>
        <% if (typeof user !=='undefined' && user) { %>
          <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i></a>
          <% } %>
      </div>
    </div>
  </div>

  <!-- Page Header -->
  <header class="contact-header">
    <h1 class="serif">Get in Touch</h1>
    <p>We are here to assist you with any inquiries</p>
  </header>

  <!-- Two-Column Section -->
  <section class="contact-layout">
    <!-- Left: Contact Info -->
    <div class="contact-info">
      <div class="info-block">
        <h3 class="serif">Boutique Location</h3>
        <p>
          <i class="fas fa-map-marker-alt"></i>
          123 Luxury Street<br>
          Fifth Avenue, Suite 400<br>
          New York, NY 10001
        </p>
      </div>

      <div class="info-block">
        <h3 class="serif">Direct Contact</h3>
        <a href="tel:+1234567890">
          <i class="fas fa-phone"></i>
          +1 234 567 890
        </a>
        <a href="mailto:concierge@luxetime.com">
          <i class="fas fa-envelope"></i>
          concierge@luxetime.com
        </a>
      </div>

      <div class="info-block">
        <h3 class="serif">Business Hours</h3>
        <p>
          <i class="fas fa-clock"></i>
          Monday - Friday: 10:00 AM - 7:00 PM<br>
          Saturday: 11:00 AM - 6:00 PM<br>
          Sunday: Closed
        </p>
      </div>

      <div class="info-block">
        <h3 class="serif">Follow Us</h3>
        <div class="social-row">
          <a href="#"><i class="fab fa-instagram"></i></a>
          <a href="#"><i class="fab fa-facebook-f"></i></a>
          <a href="#"><i class="fab fa-pinterest-p"></i></a>
          <a href="#"><i class="fab fa-twitter"></i></a>
        </div>
      </div>
    </div>

    <!-- Right: Contact Form -->
    <div class="contact-form-wrapper">
      <form class="contact-form" action="#" method="post">
        <div class="form-group">
          <label for="name">Full Name</label>
          <input type="text" id="name" name="name" placeholder="E.g., James Bond" required>
        </div>

        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required>
        </div>

        <div class="form-group">
          <label for="phone">Phone Number (Optional)</label>
          <input type="tel" id="phone" name="phone" placeholder="+1 (555) 000-0000">
        </div>

        <div class="form-group">
          <label for="subject">Subject</label>
          <select id="subject" name="subject" required>
            <option value="" disabled selected>Select an inquiry type</option>
            <option value="sales">Sales & Purchases</option>
            <option value="service">Service & Repair</option>
            <option value="returns">Returns & Exchanges</option>
            <option value="other">Other Inquiry</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Your Message</label>
          <textarea id="message" name="message" placeholder="How can we assist you today?" required></textarea>
        </div>

        <button type="submit" class="btn-submit">Send Message</button>
      </form>
    </div>
  </section>

  <!-- Map Section -->
  <div class="map-section">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d24190.412269372186!2d-74.00594195015682!3d40.71277603519483!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c25a17c92bf8df%3A0x5d6f31b0e7e3e10!2sNew%20York!5e0!3m2!1sen!2sus!4v1614039288543!5m2!1sen!2sus"
      allowfullscreen="" loading="lazy">
    </iframe>
  </div>

  <!-- FAQ Teaser -->
  <section class="faq-teaser">
    <h2 class="serif">Looking for quick answers?</h2>
    <ul class="faq-list">
      <li>
        <a href="#">What is your return policy? <i class="fas fa-arrow-right"></i></a>
      </li>
      <li>
        <a href="#">Do you offer international shipping? <i class="fas fa-arrow-right"></i></a>
      </li>
      <li>
        <a href="#">How do I verify the authenticity of a watch? <i class="fas fa-arrow-right"></i></a>
      </li>
      <li>
        <a href="#">What does your warranty cover? <i class="fas fa-arrow-right"></i></a>
      </li>
    </ul>
  </section>

  <!-- Footer -->
  <footer class="footer-luxury">
    <div class="footer-grid">
      <div class="footer-col">
        <h2 class="serif" style="color: var(--ivory); margin-bottom: 20px;">LUXE TIME</h2>
        <p>Curators of fine timepieces. We believe that a watch is more than an accessory; it is a legacy passed down
          through generations. Authenticity and excellence guaranteed.</p>
        <div class="social-links">
          <a href="#"><i class="fa-brands fa-instagram"></i></a>
          <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
          <a href="#"><i class="fa-brands fa-twitter"></i></a>
          <a href="#"><i class="fa-brands fa-pinterest-p"></i></a>
        </div>
      </div>
      <div class="footer-col">
        <h4>Customer Care</h4>
        <a href="/contact">Contact Us</a>
        <a href="#">Shipping & Returns</a>
        <a href="#">Warranty</a>
        <a href="#">FAQ</a>
        <a href="#">Watch Care Guide</a>
      </div>
      <div class="footer-col">
        <h4>Quick Links</h4>
        <a href="/shope">Shop All</a>
        <a href="/shope">New Arrivals</a>
        <a href="#">Pre-Owned</a>
        <a href="/blog">The Journal</a>
        <a href="#">Our Story</a>
      </div>
      <div class="footer-col">
        <h4>Newsletter</h4>
        <p>Subscribe to receive updates, access to exclusive deals, and more.</p>
        <form class="newsletter-form">
          <input type="email" placeholder="ENTER YOUR EMAIL" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> Luxe Time World. All Rights Reserved. Designed with elegance.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>